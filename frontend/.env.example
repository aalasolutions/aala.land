# Frontend config.
# API_BASE: LOCAL host dev only (pnpm start). The Docker/prod build ignores it (not a build arg) and uses
# the relative /v1, which nginx proxies to backend:3010 same-origin. Do NOT point a deployed frontend at localhost.
API_BASE=http://localhost:3010/v1
# GOOGLE_CLIENT_ID: baked into the bundle at build time (the only frontend build arg). On deploy it is
# single-sourced from backend/.env; set here only to override for local dev.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# FRONTEND_HOST_PORT: port published on the HOST (what your reverse proxy hits). The container serves nginx on 8080.
# Compose mapping is "${FRONTEND_HOST_PORT:-7102}:8080" (host:container). On a staging stack set a free port (e.g. 7103).
FRONTEND_HOST_PORT=7102
# STACK_NAME is not set here; it is read from backend/.env by the deploy scripts.
