<div class="flex col gap-2">
  <label class="font-sm text-muted" for={{@id}}>{{@label}}{{#if @required}} *{{/if}}</label>
  <textarea
    id={{@id}}
    class="form-input"
    rows={{@rows}}
    placeholder={{@placeholder}}
    required={{@required}}
    {{on "input" @onChange}}
  >{{@value}}</textarea>
</div>