{{#if this.isSuccess}}
  <div data-test-reset-password-success class="flex col gap-5 w-full text-center">
    <div class="flex col gap-2">
      <Ph @icon="check-circle" @size="48px" />
      <p class="font-sm text-muted">Password updated successfully.</p>
    </div>

    <p class="font-sm text-muted">
      Ready to continue?
      <LinkTo @route="login" class="text-primary" data-test-reset-password-login-link>
        Sign in
      </LinkTo>
    </p>
  </div>
{{else}}
  {{#if this.hasToken}}
    <form
      data-test-reset-password-form
      class="flex col gap-4 w-full"
      {{on "submit" this.submit}}
    >
      <FormInput
        @label="New Password"
        @id="reset-password"
        @type="password"
        @placeholder="Min 8 characters"
        @value={{this.password}}
        @required={{true}}
        @autocomplete="new-password"
        @onChange={{fn this.updateField "password"}}
        data-test-reset-password-input
      />

      <FormInput
        @label="Confirm Password"
        @id="reset-password-confirm"
        @type="password"
        @placeholder="Repeat your password"
        @value={{this.confirmPassword}}
        @required={{true}}
        @autocomplete="new-password"
        @onChange={{fn this.updateField "confirmPassword"}}
        data-test-reset-password-confirm-input
      />

      {{#if this.errorMessage}}
        <div
          data-test-reset-password-error
          class="p-3 rounded-lg bg-danger@10 border border-danger@20 text-danger text-center font-sm"
        >
          {{this.errorMessage}}
        </div>
      {{/if}}

      <AppButton
        @variant="primary"
        @buttonType="submit"
        @text="Update Password"
        @loading={{this.isLoading}}
        @loadingText="Updating Password..."
        @disabled={{not this.canSubmit}}
        data-test-reset-password-submit
        class="btn-lg w-full py-4 rounded-xl font-bold"
      />
    </form>
  {{else}}
    <div data-test-reset-password-token-error class="flex col gap-4 w-full text-center">
      <p class="font-sm text-danger">Invalid reset link.</p>
      <LinkTo @route="login" class="text-primary" data-test-reset-password-login-link>
        Sign in
      </LinkTo>
    </div>
  {{/if}}
{{/if}}
