<form
  data-test-signup-form
  class="flex col gap-4 w-full"
  {{on "submit" this.submit}}
>
  <div class="grid col gap-4">
    <Ui::FormInput
      @label="Company Name"
      @id="signup-company"
      @type="text"
      @placeholder="Acme Real Estate"
      @value={{this.companyName}}
      @required={{true}}
      @onChange={{fn this.updateField "companyName"}}
      data-test-company-name
    />

    <div class="flex col gap-1 signup-slug-field">
      <Ui::FormInput
        @label="Company URL Slug"
        @id="signup-slug"
        @type="text"
        @placeholder="acme-real-estate"
        @value={{this.companySlug}}
        @required={{true}}
        @onChange={{fn this.updateField "companySlug"}}
        data-test-company-slug
      />
      <p class="text-muted px-1 text-xs">Lowercase, numbers, and hyphens only.</p>
    </div>
  </div>

  <Ui::FormDropdown
    @label="Primary Operating Region"
    @id="signup-region"
    @value={{this.selectedRegion}}
    @options={{this.regionOptions}}
    @onChange={{this.selectRegion}}
    @placeholder="Select your region..."
    @required={{true}}
    data-test-region-select
  />

  <hr class="border-white@10 my-1" />

  <div class="grid cols-2 gap-4">
    <Ui::FormInput
      @label="Your Name"
      @id="signup-name"
      @type="text"
      @placeholder="Jane Smith"
      @value={{this.userName}}
      @required={{true}}
      @onChange={{fn this.updateField "userName"}}
      data-test-user-name
    />

    <Ui::FormInput
      @label="Email Address"
      @id="signup-email"
      @type="email"
      @placeholder="jane@company.com"
      @value={{this.email}}
      @required={{true}}
      @autocomplete="email"
      @onChange={{fn this.updateField "email"}}
      data-test-email-input
    />
  </div>

  <div class="grid cols-2 gap-4">
    <Ui::FormInput
      @label="Password"
      @id="signup-password"
      @type="password"
      @placeholder="Min 8 characters"
      @value={{this.password}}
      @required={{true}}
      @autocomplete="new-password"
      @onChange={{fn this.updateField "password"}}
      data-test-password-input
    />
    <Ui::FormInput
      @label="Confirm Password"
      @id="signup-confirm"
      @type="password"
      @placeholder="••••••••"
      @value={{this.confirmPassword}}
      @required={{true}}
      @autocomplete="new-password"
      @onChange={{fn this.updateField "confirmPassword"}}
      data-test-confirm-password
    />
  </div>

  {{#if this.errorMessage}}
    <div
      class="p-3 rounded-lg bg-danger@10 border border-danger@20 text-danger text-center font-sm"
    >
      {{this.errorMessage}}
    </div>
  {{/if}}

  <button
    data-test-submit-button
    type="submit"
    class="btn btn-primary btn-lg w-full py-4 rounded-xl font-bold mt-2"
    disabled={{or this.isLoading (not this.canSubmit)}}
  >
    {{#if this.isLoading}}
      <span class="flex x-center center gap-2">
        <Ui::Ph @icon="circle-notch" class="animate-spin" />
        Creating Account...
      </span>
    {{else}}
      Create Workspace with Email
    {{/if}}
  </button>

  {{#if this.googleAuth.isConfigured}}
    <div class="divider">
      <span class="text-muted font-sm">OR</span>
    </div>

    {{#if this.canGoogleSignup}}
      <div
        class="google-signin-section
          {{unless this.isGoogleLoading 'auth-google-button'}}"
      >
        {{#if this.isGoogleLoading}}
          <button
            type="button"
            class="btn btn--google btn--google--loading"
            disabled
          >
            <span class="google-spinner"></span>
          </button>
        {{else}}
          <div
            id="google-signup-button"
            class="google-button-host"
            {{did-insert this.renderGoogleButton}}
          ></div>
        {{/if}}
      </div>
    {{else}}
      <button
        type="button"
        class="auth-google-button auth-google-button--blocked"
        aria-label="Continue with Google"
        {{on "click" this.showGoogleSignupRequirements}}
        data-test-google-signup-disabled
      ></button>
    {{/if}}
  {{/if}}
</form>