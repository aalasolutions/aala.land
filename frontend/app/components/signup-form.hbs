<form
  data-test-signup-form
  class="flex col gap-5 w-full"
  {{on "submit" this.submit}}
>
  {{! Company Info }}
  <div class="flex col gap-2">
    <label class="font-sm text-muted" for="signup-company">Company Name</label>
    <input
      data-test-company-name
      id="signup-company"
      type="text"
      class="px-4 py-3 rounded-xl bg-white border border-white@10 text-color font-sm outline-none"
      placeholder="Acme Real Estate"
      value={{this.companyName}}
      required
      {{on "input" (fn this.updateField "companyName")}}
    />
  </div>

  <div class="flex col gap-2">
    <label class="font-sm text-muted" for="signup-slug">Company URL Slug</label>
    <input
      data-test-company-slug
      id="signup-slug"
      type="text"
      class="px-4 py-3 rounded-xl bg-white border border-white@10 text-color font-sm outline-none"
      placeholder="acme-real-estate"
      value={{this.companySlug}}
      required
      {{on "input" (fn this.updateField "companySlug")}}
    />
    <p class="font-xs text-muted">Lowercase letters, numbers, and hyphens only.</p>
  </div>

  {{! Region Picker }}
  <div class="flex col gap-2">
    <label class="font-sm font-bold text-muted uppercase">Select Your Region</label>

    {{#each @countries as |countryCode|}}
      <div class="mt-3">
        <p class="font-xs font-bold text-muted uppercase mb-1">{{countryCode}}</p>
        <div class="region-grid">
          {{#each (get @grouped countryCode) as |r|}}
            <label class="region-checkbox" data-test-region-option={{r.code}}>
              <input
                type="radio"
                name="signup-region"
                checked={{eq r.code this.selectedRegion}}
                {{on "change" (fn this.selectRegion r.code)}}
              />
              <span class="region-check-label">
                {{r.name}} <span class="text-muted font-xs">({{r.currency}})</span>
              </span>
            </label>
          {{/each}}
        </div>
      </div>
    {{/each}}
  </div>

  {{! Admin User }}
  <div class="flex col gap-2">
    <label class="font-sm text-muted" for="signup-name">Your Name</label>
    <input
      data-test-user-name
      id="signup-name"
      type="text"
      class="px-4 py-3 rounded-xl bg-white border border-white@10 text-color font-sm outline-none"
      placeholder="Jane Smith"
      value={{this.userName}}
      required
      {{on "input" (fn this.updateField "userName")}}
    />
  </div>

  <div class="flex col gap-2">
    <label class="font-sm text-muted" for="signup-email">Email</label>
    <input
      data-test-email-input
      id="signup-email"
      type="email"
      class="px-4 py-3 rounded-xl bg-white border border-white@10 text-color font-sm outline-none"
      placeholder="jane@company.com"
      value={{this.email}}
      autocomplete="email"
      required
      {{on "input" (fn this.updateField "email")}}
    />
  </div>

  <div class="flex col gap-2">
    <label class="font-sm text-muted" for="signup-password">Password</label>
    <input
      data-test-password-input
      id="signup-password"
      type="password"
      class="px-4 py-3 rounded-xl bg-white border border-white@10 text-color font-sm outline-none"
      placeholder="Min 8 characters"
      value={{this.password}}
      autocomplete="new-password"
      required
      {{on "input" (fn this.updateField "password")}}
    />
  </div>

  <div class="flex col gap-2">
    <label class="font-sm text-muted" for="signup-confirm">Confirm Password</label>
    <input
      data-test-confirm-password
      id="signup-confirm"
      type="password"
      class="px-4 py-3 rounded-xl bg-white border border-white@10 text-color font-sm outline-none"
      placeholder="••••••••"
      value={{this.confirmPassword}}
      autocomplete="new-password"
      required
      {{on "input" (fn this.updateField "confirmPassword")}}
    />
  </div>

  {{#if this.errorMessage}}
    <p data-test-error-message class="font-sm text-danger text-center">
      {{this.errorMessage}}
    </p>
  {{/if}}

  <button
    data-test-submit-button
    type="submit"
    class="px-4 py-3 rounded-xl bg-primary text-white font-sm font-bold transition"
    disabled={{or this.isLoading (not this.canSubmit)}}
  >
    {{#if this.isLoading}}
      Creating account...
    {{else}}
      Create Account
    {{/if}}
  </button>
</form>
