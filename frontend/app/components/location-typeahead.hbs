<div class="location-typeahead" data-test-location-typeahead>
  <div class="typeahead-input-wrap">
    <input
      data-test-typeahead-input
      type="text"
      class="form-input"
      placeholder={{this.placeholder}}
      value={{this.displayValue}}
      autocomplete="off"
      {{on "input" this.onInput}}
      {{on "focus" this.onFocus}}
      {{on "blur" this.onBlur}}
    />
    {{#if this.isSearching}}
      <span class="typeahead-spinner font-xs text-muted">...</span>
    {{/if}}
  </div>

  {{#if this.showDropdown}}
    <div
      class="typeahead-dropdown {{if this.isInModal 'typeahead-dropdown--floating'}}"
      data-test-typeahead-dropdown
      style={{this.dropdownStyle}}
    >
      {{#if this.canCreate}}
        <button
          type="button"
          class="typeahead-item typeahead-item--create"
          data-test-typeahead-create
          disabled={{this.isCreating}}
          {{on "mousedown" this.createNew}}
        >
          {{#if this.isCreating}}
            <span class="typeahead-item-name typeahead-item-name--create">Creating...</span>
          {{else}}
            <span class="typeahead-item-name typeahead-item-name--create">
              <span class="typeahead-item-name-emphasis">Add</span>
              <span class="typeahead-item-name-emphasis">"</span>{{this.trimmedQuery}}<span class="typeahead-item-name-emphasis">"</span>
            </span>
          {{/if}}
        </button>
      {{/if}}

      {{#each this.uniqueResults as |item|}}
        <button
          type="button"
          class="typeahead-item"
          data-test-typeahead-item={{item.id}}
          {{on "mousedown" (fn this.selectItem item)}}
        >
          <span class="typeahead-item-name typeahead-item-name--result">{{item.name}}</span>
        </button>
      {{/each}}

      {{#if (and (eq this.uniqueResults.length 0) (not this.isSearching))}}
        {{#unless this.canCreate}}
          <div class="typeahead-item text-muted font-xs">No matches found</div>
        {{/unless}}
      {{/if}}
    </div>
  {{/if}}
</div>
