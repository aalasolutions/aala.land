{{#if this.showForgotPassword}}
  {{#if this.resetSent}}
    <div data-test-reset-success class="flex col gap-5 w-full text-center">
      <div class="flex col gap-2">
        <Ph @icon="check-circle" @size="48px" />
        <p class="font-sm text-muted">
          If an account exists with that email, you will receive a password reset link.
        </p>
      </div>
      <button
        data-test-back-to-login
        type="button"
        class="btn-link text-primary font-sm"
        {{on "click" this.toggleForgotPassword}}
      >
        Sign in
      </button>
    </div>
  {{else}}
    <form
      data-test-forgot-password-form
      class="flex col gap-5 w-full"
      {{on "submit" this.submitForgotPassword}}
    >
      <FormInput
        @label="Email"
        @id="reset-email"
        @type="email"
        @placeholder="you@company.com"
        @value={{this.resetEmail}}
        @autocomplete="email"
        @required={{true}}
        @onChange={{this.updateResetEmail}}
        data-test-reset-email-input
      />

      {{#if this.resetError}}
        <p data-test-reset-error class="font-sm text-danger text-center">
          {{this.resetError}}
        </p>
      {{/if}}

      <AppButton
        @variant="primary"
        @buttonType="submit"
        @text="Send Reset Link"
        @loading={{this.resetLoading}}
        @loadingText="Sending..."
        data-test-reset-submit
      />

      <div class="text-center text-muted">
        <button
          data-test-back-to-login
          type="button"
          class="btn-link font-sm text-muted"
          {{on "click" this.toggleForgotPassword}}
        >
          Back to Sign In
        </button>
      </div>
    </form>
  {{/if}}
{{else}}
  <form
    data-test-login-form
    class="flex col gap-5 w-full"
    {{on "submit" this.submit}}
  >
    <FormInput
      @label="Email"
      @id="login-email"
      @type="email"
      @placeholder="you@company.com"
      @value={{this.email}}
      @autocomplete="email"
      @required={{true}}
      @onChange={{this.updateEmail}}
      data-test-email-input
    />

    <FormInput
      @label="Password"
      @id="login-password"
      @type="password"
      @placeholder="••••••••"
      @value={{this.password}}
      @autocomplete="current-password"
      @required={{true}}
      @onChange={{this.updatePassword}}
      data-test-password-input
    />

    {{#if this.errorMessage}}
      <p data-test-error-message class="font-sm text-danger text-center">
        {{this.errorMessage}}
      </p>
    {{/if}}

    <AppButton
      @variant="primary"
      @buttonType="submit"
      @text="Sign In"
      @loading={{this.isLoading}}
      @loadingText="Signing in..."
      data-test-submit-button
    />

    <div class="text-center">
      <button
        data-test-forgot-password-link
        type="button"
        class="btn-link font-sm text-muted"
        {{on "click" this.toggleForgotPassword}}
      >
        Forgot Password?
      </button>
    </div>
  </form>
{{/if}}
