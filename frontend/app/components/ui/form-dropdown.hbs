<div class="flex col gap-2">
  <label class="font-sm text-muted" for={{@id}}>{{@label}}{{#if @required}}
      *{{/if}}</label>

  <div class="form-dropdown" ...attributes>
    <div class="dropdown-container">
      <input
        type="text"
        id={{@id}}
        class="dropdown-trigger form-input"
        readonly
        disabled={{@disabled}}
        value={{this.displayText}}
        {{on "click" this.toggleDropdown}}
        {{on "keydown" this.handleKeydown}}
      />
      <span class="dropdown-arrow {{if this.isOpen 'open'}}">
        <Ui::Ph @icon="caret-down" @size="16px" />
      </span>

      {{#if this.isOpen}}
        <div
          class="dropdown-menu open
            {{if
              (and
                this.dropdownPosition
                (and this.dropdownPosition.openUpward (not this.isInModal))
              )
              'open-upward'
            }}
            {{if this.isInModal 'in-modal-dropdown'}}"
          style={{this.dropdownMenuStyle}}
        >
          {{#if this.showSearch}}
            <div class="dropdown-search">
              <input
                type="text"
                class="form-input"
                placeholder="Search..."
                value={{this.searchText}}
                {{on "input" this.updateSearch}}
                {{on "keydown" this.handleKeydown}}
              />
            </div>
          {{/if}}

          <div class="dropdown-options" role="listbox" aria-labelledby={{@id}}>
            {{#if this.filteredOptions.length}}
              {{#each this.groupedOptions as |grp|}}
                {{#if grp.group}}
                  <div class="dropdown-group-label" role="presentation">
                    {{grp.group}}
                  </div>
                {{/if}}
                {{#each grp.options as |row|}}
                  <div
                    class="dropdown-option
                      {{if (eq @value row.option.value) 'selected'}}
                      {{if (eq this.highlightedIndex row.index) 'highlighted'}}"
                    role="option"
                    aria-selected={{if
                      (eq @value row.option.value)
                      "true"
                      "false"
                    }}
                    {{on "click" (fn this.selectOption row.option)}}
                  >
                    {{row.option.label}}
                  </div>
                {{/each}}
              {{/each}}
            {{else}}
              <div class="dropdown-no-results">
                No results found
              </div>
            {{/if}}
          </div>
        </div>
      {{/if}}
    </div>
  </div>
</div>