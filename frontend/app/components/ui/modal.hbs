{{#if @isOpen}}
  <div class="modal-backdrop" {{on "click" this.close}}>
    <div
      class="modal-panel {{@panelClass}}"
      role="dialog"
      aria-modal="true"
      aria-labelledby={{if @title "modal-title"}}
      {{on "click" this.stopPropagation}}
      ...attributes
    >
      {{#if (or @title @showClose)}}
        <div class="modal-header">
          <h2 id="modal-title">{{@title}}</h2>
          {{#if @showClose}}
            <button
              type="button"
              class="modal-close-btn"
              aria-label="Close"
              {{on "click" this.close}}
            >
              <Ui::Ph @icon="x" @size="20px" />
            </button>
          {{/if}}
        </div>
      {{/if}}

      <div class="modal-content flex col gap-6">
        {{yield}}
      </div>
    </div>
  </div>
{{/if}}