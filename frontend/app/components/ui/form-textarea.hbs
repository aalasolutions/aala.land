<div class="flex col gap-2">
  <label class="font-sm text-muted" for={{@id}}>{{@label}}{{#if @required}} *{{/if}}</label>
  <textarea
    id={{@id}}
    class="form-input"
    name={{@name}}
    rows={{@rows}}
    placeholder={{@placeholder}}
    required={{@required}}
    disabled={{@disabled}}
    readonly={{@readonly}}
    autocomplete={{@autocomplete}}
    {{on "input" this.handleInput}}
    ...attributes
  >{{@value}}</textarea>
</div>
