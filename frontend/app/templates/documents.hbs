{{page-title "Documents"}}

<div data-test-documents class="flex col gap-6">
  <div class="flex between x-center">
    <div class="flex x-center gap-3">
      <Ph @icon="file-arrow-up" @size="24px" />
      <h2 class="font-2xl font-bold">Documents</h2>
      <span class="text-muted font-sm">({{format-number @model.total}})</span>
    </div>
    <button type="button" class="btn btn-primary" data-test-upload-btn {{on "click" this.openCreate}}>
      <Ph @icon="upload-simple" /> Upload Document
    </button>
  </div>

  <div class="flex gap-3">
    <FormDropdown @id="document-category-filter" @label="" @value={{this.category}} @onChange={{this.setCategory}} @options={{this.categories}} @placeholder="All Categories" data-test-category-filter />
  </div>

  {{#if @model.documents.length}}
    <div>
      <div class="data-table-wrapper data-table-wrapper--with-pagination">
        <table class="data-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Category</th>
              <th>Access</th>
              <th>Type</th>
              <th>Version</th>
              <th>Uploaded</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {{#each @model.documents as |doc|}}
              <tr data-test-document-row>
                <td>
                  <div class="flex x-center gap-2">
                    <Ph @icon={{this.fileIcon doc.fileType}} />
                    <span class="font-bold">{{doc.name}}</span>
                  </div>
                </td>
                <td><span class="type-badge type-{{lowercase doc.category}}">{{doc.category}}</span></td>
                <td><span class="status-badge status-{{lowercase doc.accessLevel}}">{{doc.accessLevel}}</span></td>
                <td class="font-sm text-muted">{{doc.fileType}}</td>
                <td class="font-sm">v{{doc.version}}</td>
                <td class="font-sm text-muted">{{format-date doc.createdAt}}</td>
                <td>
                  <div class="flex gap-2">
                    <button type="button" class="btn btn-secondary btn-xs" data-test-download-btn {{on "click" (fn this.downloadDocument doc)}}>
                      <Ph @icon="download-simple" />
                    </button>
                    <button type="button" class="btn btn-secondary btn-xs" {{on "click" (fn this.openEdit doc)}}>
                      <Ph @icon="pencil-simple" />
                    </button>
                    <button type="button" class="btn btn-danger btn-xs" {{on "click" (fn this.openDelete doc)}}>
                      <Ph @icon="trash" />
                    </button>
                  </div>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>

      <Pagination
        @selectId="documents-limit"
        @page={{this.page}}
        @limit={{this.limit}}
        @total={{@model.total}}
        @onLimitChange={{this.setLimit}}
        @onPrevious={{this.goToPreviousPage}}
        @onNext={{this.goToNextPage}}
      />
    </div>
  {{else}}
    <div class="glass-panel p-8 text-center">
      <Ph @icon="file-arrow-up" @size="48px" @color="var(--text-muted)" />
      <p class="text-muted mt-3">No documents yet. Upload your first document above.</p>
    </div>
  {{/if}}
</div>

<Modal
  @isOpen={{this.showModal}}
  @title={{if this.editDocument "Update Document" "Upload Document"}}
  @onClose={{this.closeModal}}
  @showClose={{true}}
>
  <form class="flex col gap-4" {{on "submit" this.saveDocument}}>
    <div class="flex col gap-2">
      <label class="font-sm text-muted" for="d-file">File {{unless this.editDocument "*"}}</label>
      <input id="d-file" type="file" class="form-input" data-test-file-input
        accept=".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png,.webp,.gif"
        {{on "change" this.onFileSelect}} />
      {{#if this.selectedFile}}
        <p class="font-xs text-muted">Selected: {{this.selectedFile.name}} ({{this.selectedFile.size}} bytes)</p>
      {{/if}}
    </div>

    <FormInput @label="Document Name" @id="d-name" @type="text" @placeholder="Lease Agreement Q1 2026" @value={{this.formName}} @onChange={{fn this.setField "formName"}} @required={{true}} data-test-field-name />

    <div class="flex gap-4">
      <div class="flex col gap-2 flex-1">
        <FormDropdown @label="Category" @id="d-category" @value={{this.formCategory}} @onChange={{fn this.setField "formCategory"}} @options={{this.categoryOptions}} @placeholder="Select category..." data-test-field-category />
      </div>
      <div class="flex col gap-2 flex-1">
        <FormDropdown @label="Access Level" @id="d-access" @value={{this.formAccessLevel}} @onChange={{fn this.setField "formAccessLevel"}} @options={{this.accessLevels}} @placeholder="Select access level..." data-test-field-access />
      </div>
    </div>

    {{#if this.uploadProgress}}
      <p class="font-sm text-muted">{{this.uploadProgress}}</p>
    {{/if}}

    {{#if this.errorMsg}}
      <p class="font-sm text-danger" data-test-error>{{this.errorMsg}}</p>
    {{/if}}

    <div class="flex gap-3 mt-2">
      <AppButton @variant="secondary" @text="Cancel" @onClick={{this.closeModal}} />
      <AppButton @variant="primary" @buttonType="submit" @text={{if this.editDocument "Update" "Upload"}} @loading={{this.isSaving}} @loadingText="Uploading..." data-test-save-btn />
    </div>
  </form>
</Modal>

<ConfirmModal
  @isOpen={{this.showDeleteModal}}
  @title="Delete Document"
  @message="Are you sure you want to delete {{this.documentToDelete.name}}? This action cannot be undone."
  @confirmText="Delete"
  @cancelText="Cancel"
  @confirmType="btn-danger"
  @isConfirming={{this.isDeleting}}
  @confirmingText="Deleting..."
  @onClose={{this.closeDeleteModal}}
  @onConfirm={{this.confirmDelete}}
/>
