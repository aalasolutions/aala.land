{{page-title "WhatsApp"}}

<div data-test-whatsapp-page class="wa-page">

  {{!-- ── Left sidebar ─────────────────────────────────────────────── --}}
  <aside class="wa-sidebar">

    {{!-- Header --}}
    <div class="wa-sidebar-header">
      <span class="font-bold">WhatsApp</span>
      <div class="flex gap-2 x-center">
        <button
          type="button"
          class="wa-ai-toggle {{if this.aiEnabled 'active'}} {{unless this.aiKeyConfigured 'disabled'}}"
          title={{if this.aiKeyConfigured "Toggle AI auto-reply" "No AI key configured"}}
          {{on "click" this.toggleAi}}
        >
          AI: {{if this.aiEnabled "on" "off"}}
        </button>
        <button type="button" class="wa-repairBtn" title="Re-pair device" {{on "click" this.repairWhatsapp}}>
          Re-pair
        </button>
      </div>
    </div>

    {{!-- Connection status --}}
    <div class="wa-status-bar">
      <span class="wa-dot {{this.connection}}"></span>
      <span>
        {{#if (eq this.connection "connected")}}
          Connected
        {{else if (eq this.connection "connecting")}}
          Connecting...
        {{else}}
          {{if this.hasCredentials "Reconnecting..." "Not paired"}}
        {{/if}}
      </span>
    </div>

    {{!-- QR pane --}}
    {{#if this.showQR}}
      <div class="wa-qr-pane">
        <p class="font-bold">Connect your WhatsApp</p>
        {{#if this.qr}}
          <div class="wa-qr-frame">
            <img src={{this.qr}} alt="WhatsApp QR code" class="wa-qr-img" />
          </div>
        {{else}}
          <div class="wa-qr-frame">
            <span class="wa-qr-placeholder">Generating QR...</span>
          </div>
        {{/if}}
        <ol class="wa-qr-steps">
          <li>Open WhatsApp on your phone</li>
          <li>Tap Settings → Linked Devices</li>
          <li>Tap "Link a Device"</li>
          <li>Point your phone at this screen</li>
        </ol>
      </div>
    {{/if}}

    {{!-- Chat list --}}
    {{#unless this.showQR}}
      <div class="wa-chat-list">
        {{#each this.chats as |chat|}}
          <button
            type="button"
            class="wa-chat-item {{if (eq this.currentChatId chat.chatId) 'active'}}"
            {{on "click" (fn this.selectChat chat.chatId)}}
          >
            <div class="flex between x-center">
              <span class="wa-chat-name">
                {{#if chat.isGroup}}<span class="wa-group-tag">group</span>{{/if}}
                {{chat.chatName}}
              </span>
              <span class="wa-chat-time">{{format-date-time chat.lastTs}}</span>
            </div>
            <p class="wa-chat-preview">
              {{#if chat.lastFromMe}}You: {{/if}}{{chat.lastBody}}
            </p>
          </button>
        {{else}}
          {{#if this.isConnected}}
            <p class="wa-empty-list">No chats yet.</p>
          {{/if}}
        {{/each}}
      </div>
    {{/unless}}

  </aside>

  {{!-- ── Main chat area ────────────────────────────────────────────── --}}
  <main class="wa-chat-area">

    {{#if this.currentChatId}}

      {{!-- Chat header --}}
      <div class="wa-chat-header">
        <div>
          <div class="font-bold">{{this.currentChatName}}</div>
          <div class="wa-chat-header-id">{{this.currentChatId}}</div>
        </div>
      </div>

      {{!-- Messages --}}
      <div class="wa-messages" id="wa-messages-container">
        {{#each this.currentChatMessages as |msg|}}
          <div class="wa-message {{if msg.fromMe 'outgoing' 'incoming'}} {{if msg.aiGenerated 'ai'}}">
            {{#unless msg.fromMe}}
              <div class="wa-sender-tag">{{msg.senderName}}</div>
            {{/unless}}
            <div class="wa-bubble" dir="auto">{{~#if msg.hasMedia~}}{{~#if (or (eq msg.mediaType "image") (eq msg.mediaType "sticker"))~}}<img src={{this.mediaUrl msg}} alt="image" class="wa-media-img" loading="lazy" />{{~else if (eq msg.mediaType "video")~}}<video src={{this.mediaUrl msg}} controls class="wa-media-video"></video>{{~else if (or (eq msg.mediaType "audio") (eq msg.mediaType "ptt"))~}}<audio src={{this.mediaUrl msg}} controls class="wa-media-audio"></audio>{{~else if (eq msg.mediaType "document")~}}<a href={{this.mediaUrl msg}} target="_blank" rel="noopener noreferrer" class="wa-media-doc">{{msg.body}}</a>{{~/if~}}{{~else~}}{{msg.body}}{{~/if~}}</div>
            <div class="wa-meta">
              {{format-date-time msg.timestamp}}
              {{#if msg.fromMe}}
                {{#if msg.aiGenerated}}
                  · <span class="wa-ai-tag">AI</span>
                {{else}}
                  · You
                {{/if}}
              {{/if}}
            </div>
          </div>
        {{else}}
          <div class="wa-empty-state">No messages in this chat yet.</div>
        {{/each}}
      </div>

      {{!-- Input --}}
      {{#if this.isConnected}}
        <div class="wa-input-area">
          {{#if this.errorMsg}}
            <p class="wa-error">{{this.errorMsg}}</p>
          {{/if}}
          <div class="wa-input-row">
            <textarea
              class="wa-input"
              placeholder="Type a message..."
              rows="1"
              value={{this.messageText}}
              {{on "input" this.setMessageText}}
              {{on "keydown" this.handleKeydown}}
            ></textarea>
            <button type="button" class="wa-send-btn" disabled={{this.isSending}} {{on "click" this.sendMessage}}>
              Send
            </button>
          </div>
        </div>
      {{/if}}

    {{else}}

      {{!-- Empty state --}}
      <div class="wa-empty-state">
        {{if this.isConnected "Select a chat from the sidebar to start messaging." "Pair your WhatsApp to begin."}}
      </div>

    {{/if}}

  </main>

</div>
