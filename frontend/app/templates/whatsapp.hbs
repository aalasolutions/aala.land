{{page-title "WhatsApp"}}

<div data-test-whatsapp-page class="flex col gap-6 whatsapp-page">
  <div>
    <h2 class="font-3xl font-bold"><Ph @icon="whatsapp-logo" @size="28px" /> WhatsApp Messages</h2>
    <p class="text-muted mt-1">Conversation threads with leads.</p>
  </div>

  <div class="glass-panel flex-1 flex col overflow-hidden">
    {{#if @model.messages.length}}
      <div class="flex-1 overflow-y-auto p-4 flex col gap-3">
        {{#each @model.messages as |msg|}}
          <div
            data-test-message
            data-test-message-direction={{msg.direction}}
            class="flex {{if (eq msg.direction "OUTBOUND") "end" "start"}} gap-2"
          >
            <div class="{{if (eq msg.direction "OUTBOUND") "msg-outbound" "msg-inbound"}}">
              <p class="font-sm">{{msg.message}}</p>
              <p class="font-xs mt-1 opacity-60">{{msg.direction}} - {{msg.status}}</p>
            </div>
          </div>
        {{/each}}
      </div>
    {{else}}
      <div class="flex-1 flex center x-center">
        <p class="text-muted">No messages yet.</p>
      </div>
    {{/if}}
  </div>
</div>
