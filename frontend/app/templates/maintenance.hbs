{{page-title "Maintenance"}}

<div data-test-maintenance-page class="flex col gap-6">
  <div class="flex between x-center">
    <div>
      <h2 class="font-3xl font-bold"><Ph @icon="wrench" @size="28px" /> Maintenance</h2>
      <p class="text-muted mt-1">Track and manage property work orders.</p>
    </div>
    <button type="button" class="btn btn-primary" {{on "click" this.openCreate}}>
      <Ph @icon="plus" /> New Work Order
    </button>
  </div>

  {{#if @model.costSummary}}
    <div class="grid cols-4 gap-4">
      <div class="glass-panel p-4">
        <p class="text-muted font-xs uppercase tracking-wider mb-1">Total Estimated</p>
        <h4 class="font-xl font-bold">{{format-currency @model.costSummary.totalEstimated}}</h4>
      </div>
      <div class="glass-panel p-4">
        <p class="text-muted font-xs uppercase tracking-wider mb-1">Total Actual</p>
        <h4 class="font-xl font-bold">{{format-currency @model.costSummary.totalActual}}</h4>
      </div>
      <div class="glass-panel p-4">
        <p class="text-muted font-xs uppercase tracking-wider mb-1">Pending Cost</p>
        <h4 class="font-xl font-bold text-warning">{{format-currency @model.costSummary.pendingCost}}</h4>
      </div>
      <div class="glass-panel p-4">
        <p class="text-muted font-xs uppercase tracking-wider mb-1">Work Orders</p>
        <h4 class="font-xl font-bold">{{@model.costSummary.totalOrders}}</h4>
      </div>
    </div>
  {{/if}}

  <div class="tabs">
    <button type="button" class="tab-btn {{if (eq this.activeSection 'orders') 'active'}}" {{on "click" (fn this.setSection 'orders')}}>
      <Ph @icon="list-checks" /> Work Orders
    </button>
    <button type="button" class="tab-btn {{if (eq this.activeSection 'upcoming') 'active'}}" {{on "click" (fn this.setSection 'upcoming')}}>
      <Ph @icon="calendar-check" /> Upcoming Preventive
    </button>
  </div>

  {{#if (eq this.activeSection "orders")}}
    <div class="flex gap-4 x-center">
      <FormDropdown @id="maintenance-status-filter" @label="Status" @value={{this.filterStatus}} @onChange={{this.setStatusFilter}} @options={{this.statusOptions}} @placeholder="All" />
      <FormDropdown @id="maintenance-period-filter" @label="Period" @value={{this.filterMonth}} @onChange={{this.setMonthFilter}} @options={{this.monthOptions}} @placeholder="All" />
    </div>

    <div class="glass-panel p-5">
      {{#if this.filteredWorkOrders.length}}
        <div class="data-table-wrapper data-table-wrapper--with-pagination">
          <table class="data-table">
            <thead>
              <tr>
                <th>Title</th>
                <th>Unit</th>
                <th>Category</th>
                <th>Priority</th>
                <th>Est. Cost</th>
                <th>Actual Cost</th>
                <th>Scheduled</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {{#each this.filteredWorkOrders as |wo|}}
                <tr data-test-work-order>
                  <td>
                    <p class="font-sm font-bold">{{wo.title}}</p>
                    {{#if wo.vendorId}}<p class="text-muted font-xs"><Ph @icon="toolbox" /> Vendor assigned</p>{{/if}}
                  </td>
                  <td class="font-sm text-muted">
                    {{#if wo.unitNumber}}
                      {{wo.areaName}} / {{wo.assetName}} / {{wo.unitNumber}}
                    {{else}}
                      <span class="text-muted">-</span>
                    {{/if}}
                  </td>
                  <td><span class="type-badge type-{{lowercase wo.category}}">{{wo.category}}</span></td>
                  <td><span class="status-badge status-{{lowercase wo.priority}}">{{wo.priority}}</span></td>
                  <td>{{#if wo.estimatedCost}}{{format-currency wo.estimatedCost}}{{else}}-{{/if}}</td>
                  <td>{{#if wo.actualCost}}{{format-currency wo.actualCost}}{{else}}-{{/if}}</td>
                  <td class="font-xs">{{#if wo.scheduledDate}}{{wo.scheduledDate}}{{else}}-{{/if}}</td>
                  <td><span class="status-badge status-{{lowercase wo.status}}">{{wo.status}}</span></td>
                  <td>
                    <button type="button" class="btn btn-secondary btn-xs" {{on "click" (fn this.openEdit wo)}}>
                      <Ph @icon="pencil-simple" /> Edit
                    </button>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

        <Pagination
          @selectId="maintenance-limit"
          @page={{this.page}}
          @limit={{this.limit}}
          @total={{@model.total}}
          @onLimitChange={{this.setLimit}}
          @onPrevious={{this.goToPreviousPage}}
          @onNext={{this.goToNextPage}}
        />
      {{else}}
        {{#if @model.total}}
          <p class="text-muted text-center py-8">No work orders on this page with current filters. Navigate to find orders or adjust filters.</p>
          <Pagination
            @selectId="maintenance-limit"
            @page={{this.page}}
            @limit={{this.limit}}
            @total={{@model.total}}
            @onLimitChange={{this.setLimit}}
            @onPrevious={{this.goToPreviousPage}}
            @onNext={{this.goToNextPage}}
          />
        {{else}}
          <p class="text-muted text-center py-8">No work orders match your filters.</p>
        {{/if}}
      {{/if}}
    </div>
  {{/if}}

  {{#if (eq this.activeSection "upcoming")}}
    <div class="glass-panel p-5">
      <h4 class="font-lg font-bold mb-3"><Ph @icon="clock-countdown" /> Preventive Maintenance (Next 30 Days)</h4>
      {{#if @model.upcoming.length}}
        <div class="flex col gap-3">
          {{#each @model.upcoming as |wo|}}
            <div class="flex between x-center p-4 rounded bg-white@02 border border-white@05">
              <div class="flex col gap-1">
                <p class="font-sm font-bold">{{wo.title}}</p>
                <p class="text-muted font-xs">{{wo.category}} - Scheduled: {{wo.scheduledDate}}</p>
              </div>
              <div class="flex x-center gap-3">
                <span class="status-badge status-{{lowercase wo.priority}}">{{wo.priority}}</span>
                <button type="button" class="btn btn-secondary btn-xs" {{on "click" (fn this.openEdit wo)}}>
                  <Ph @icon="pencil-simple" /> Edit
                </button>
              </div>
            </div>
          {{/each}}
        </div>
      {{else}}
        <p class="text-muted text-center py-8">No preventive maintenance scheduled for the next 30 days.</p>
      {{/if}}
    </div>
  {{/if}}
</div>

<Modal
  @isOpen={{this.showModal}}
  @title={{if this.editWorkOrder "Edit Work Order" "New Work Order"}}
  @onClose={{this.closeModal}}
  @showClose={{true}}
>
  <form class="flex col gap-4" {{on "submit" this.saveWorkOrder}}>
    {{#unless this.editWorkOrder}}
      <FormDropdown @label="Unit" @id="wo-unit" @value={{this.formUnitId}} @onChange={{fn this.setField "formUnitId"}} @options={{this.unitOptions}} @placeholder="No unit assigned" data-test-wo-unit />
    {{/unless}}

    <FormInput @label="Title" @id="wo-title" @type="text" @placeholder="e.g. Fix leaking pipe in unit 302" @value={{this.formTitle}} @onChange={{fn this.setField "formTitle"}} @required={{true}} />

    <FormTextarea @label="Description" @id="wo-desc" @placeholder="Describe the issue in detail..." @rows={{3}} @value={{this.formDescription}} @onChange={{fn this.setField "formDescription"}} @required={{true}} />

    <div class="flex gap-4">
      <div class="flex col gap-2 flex-1">
        <FormDropdown @label="Priority" @id="wo-priority" @value={{this.formPriority}} @onChange={{fn this.setField "formPriority"}} @options={{this.priorityOptions}} @placeholder="Select priority..." />
      </div>
      <div class="flex col gap-2 flex-1">
        <FormDropdown @label="Category" @id="wo-category" @value={{this.formCategory}} @onChange={{fn this.setField "formCategory"}} @options={{this.categoryOptions}} @placeholder="Select category..." />
      </div>
    </div>

    {{#if this.editWorkOrder}}
      <FormDropdown @label="Status" @id="wo-status" @value={{this.formStatus}} @onChange={{fn this.setField "formStatus"}} @options={{this.statusOptions}} @placeholder="Select status..." />
    {{/if}}

    {{#unless this.editWorkOrder}}
      <div class="flex gap-4">
        <div class="flex col gap-2 flex-1">
          <FormInput @label="Reported By" @id="wo-reported-by" @type="text" @placeholder="Tenant or staff name" @value={{this.formReportedBy}} @onChange={{fn this.setField "formReportedBy"}} />
        </div>
        <div class="flex col gap-2 flex-1">
          <FormInput @label="Estimated Cost" @id="wo-est-cost" @type="number" @placeholder="e.g. 500" @value={{this.formEstimatedCost}} @onChange={{fn this.setField "formEstimatedCost"}} @min={{0}} @step={{0.01}} />
        </div>
      </div>
    {{else}}
      <FormInput @label="Estimated Cost" @id="wo-est-cost" @type="number" @placeholder="e.g. 500" @value={{this.formEstimatedCost}} @onChange={{fn this.setField "formEstimatedCost"}} @min={{0}} @step={{0.01}} />
    {{/unless}}

    <div class="flex gap-4">
      <div class="flex col gap-2 flex-1">
        <FormInput @label="Actual Cost" @id="wo-act-cost" @type="number" @placeholder="e.g. 450" @value={{this.formActualCost}} @onChange={{fn this.setField "formActualCost"}} @min={{0}} @step={{0.01}} />
      </div>
      <div class="flex col gap-2 flex-1">
        <FormInput @label="Cost Notes" @id="wo-cost-notes" @type="text" @placeholder="e.g. Parts + labor" @value={{this.formCostNotes}} @onChange={{fn this.setField "formCostNotes"}} />
      </div>
    </div>

    <div class="flex gap-4">
      <div class="flex col gap-2 flex-1">
        <FormInput @label="Scheduled Date" @id="wo-scheduled" @type="date" @value={{this.formScheduledDate}} @onChange={{fn this.setField "formScheduledDate"}} />
      </div>
      <div class="flex col gap-2 flex-1">
        <FormDropdown @label="Vendor" @id="wo-vendor" @value={{this.formVendorId}} @onChange={{fn this.setField "formVendorId"}} @options={{this.vendorOptions}} @placeholder="No vendor assigned" />
      </div>
    </div>

    {{#if this.errorMsg}}
      <p class="font-sm text-danger">{{this.errorMsg}}</p>
    {{/if}}

    <div class="flex gap-3 mt-2">
      <AppButton @variant="secondary" @text="Cancel" @onClick={{this.closeModal}} />
      <AppButton @variant="primary" @buttonType="submit" @text={{if this.editWorkOrder "Update" "Create Work Order"}} @loading={{this.isSaving}} @loadingText="Saving..." />
    </div>
  </form>
</Modal>
