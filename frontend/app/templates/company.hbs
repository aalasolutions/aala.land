{{page-title "Company Settings"}}

<div class="page-header">
  <div class="page-title-section">
    <h2 class="page-title"><Ph @icon="building-office" @size="28px" /> Company Settings</h2>
    <p class="page-subtitle">Manage your company information.</p>
  </div>
</div>

{{#if this.company}}
  {{#if this.isPastDue}}
    <div class="alert alert--warning mb-3" role="alert">
      <Ph @icon="warning" @size="18px" />
      Your last payment failed. Please update your payment method to avoid losing access.
    </div>
  {{/if}}
  <div class="plan-banner {{this.planTierClass}}">
    <div>
      <div class="plan-banner__name {{this.planNameClass}}">{{or this.company.subscriptionTier "FREE"}}</div>
      <div class="plan-banner__limits">{{this.planLimits}}</div>
    </div>
    {{#if this.company.subscriptionExpiresAt}}
      <div class="plan-banner__expiry">
        Expires {{format-date this.company.subscriptionExpiresAt}}
      </div>
    {{/if}}
    {{#if this.isCompanyAdmin}}
      {{#if this.isPaid}}
        <button type="button" class="btn btn-xs btn-danger-outline" {{on "click" this.confirmCancel}}>
          Cancel Subscription
        </button>
      {{else}}
        <button type="button" class="btn btn-xs btn-primary" {{on "click" this.openUpgradeModal}}>
          Upgrade
        </button>
      {{/if}}
    {{/if}}
  </div>
  <div class="company-settings-grid">
    {{! Left: Company Info }}
    <div class="glass-panel p-6">
      <h3 class="font-lg font-bold mb-4">Company Information</h3>
      <form class="flex col gap-4" {{on "submit" this.saveCompany}}>
        <FormInput @label="Company Name" @id="company-name" @type="text" @value={{or this.formName this.company.name}} @onChange={{fn this.setField "formName"}} @required={{true}} @readonly={{not this.isAdmin}} />

        <FormInput @label="Email" @id="company-email" @type="email" @value={{this.company.email}} @disabled={{true}} />

        <FormInput @label="Plan" @id="company-plan" @type="text" @value={{or this.company.subscriptionTier "FREE"}} @disabled={{true}} />

        {{#unless this.isAdmin}}
          <p class="font-sm text-muted">Only company admins and super admins can change these settings.</p>
        {{/unless}}

        {{#if this.errorMsg}}
          <p class="text-danger">{{this.errorMsg}}</p>
        {{/if}}

        <div class="form-actions">
          <AppButton @variant="primary" @buttonType="submit" @text="Save Changes" @loading={{this.isSaving}} @loadingText="Saving..." @disabled={{not this.isAdmin}} />
        </div>
      </form>
    </div>

    {{! Right: Operating Regions }}
    {{#if this.model.regions.length}}
      <div class="glass-panel p-6 {{unless this.isAdmin 'region-settings-readonly'}}" data-test-region-settings>
        <h3 class="font-lg font-bold mb-2">Operating Regions</h3>
        <p class="font-sm text-muted mb-4">
          Select states where your company operates. Your {{or this.company.subscriptionTier "FREE"}} plan includes {{if (eq this.maxCountries 999) "unlimited countries" (if (eq this.maxCountries 1) "1 country" (concat this.maxCountries " countries"))}}.
        </p>

        {{! Default Region (above the list) }}
        {{#if this.formActiveRegions.length}}
          <div class="mb-4">
            <FormDropdown @label="Default Region" @id="default-region" @value={{this.formDefaultRegionCode}} @onChange={{fn this.setField "formDefaultRegionCode"}} @options={{this.activeRegionOptions}} @placeholder="Select default region..." @disabled={{not this.isAdmin}} data-test-default-region />
          </div>
        {{/if}}

        <p class="font-sm font-bold text-muted uppercase mb-3">Available Regions</p>

        {{#each this.model.groupedRegions as |group|}}
          <div class="region-country-group mb-2 {{unless this.isAdmin 'is-readonly'}}" data-test-country-group={{group.country}}>
            <button type="button" class="region-country-header" {{on "click" (fn this.toggleCountry group.country)}}>
              <span class="country-name">{{group.countryName}}</span>
              <span class="country-meta">
                {{#let (this.selectedCountInGroup group.regions) as |count|}}
                  {{#if count}}
                    <span class="region-selected-badge">{{count}} selected</span>
                  {{/if}}
                {{/let}}
                <span class="region-total">{{group.regions.length}} states</span>
              </span>
              <Ph @icon={{if (includes this.expandedCountries group.country) "caret-up" "caret-down"}} @size="16" />
            </button>
            {{#if (includes this.expandedCountries group.country)}}
              <div class="region-grid mt-2 mb-2 ml-2">
                {{#each group.regions as |r|}}
                  <div class="region-checkbox {{unless this.isAdmin 'is-readonly'}}" data-test-region-checkbox={{r.code}}>
                    <input type="checkbox" id={{r.code}}
                      checked={{includes this.formActiveRegions r.code}}
                      disabled={{not this.isAdmin}}
                      {{on "change" (fn this.toggleRegion r.code)}} />
                    <label for={{r.code}} class="region-check-label">
                      {{r.name}} <span class="text-muted font-xs">({{r.currency}})</span>
                    </label>
                  </div>
                {{/each}}
              </div>
            {{/if}}
          </div>
        {{/each}}
      </div>
    {{/if}}
  </div>

  <Modal
    @isOpen={{this.showUpgradeModal}}
    @title="Upgrade Your Plan"
    @onClose={{this.closeUpgradeModal}}
    @showClose={{true}}
  >
    <div class="flex col gap-4">
      <p class="text-muted">Choose a plan that fits your team.</p>

      <div class="flex gap-3">
        <div class="plan-option-card {{if (eq this.company.subscriptionTier 'STARTER') 'is-current'}}">
          <div class="plan-option-card__name">STARTER</div>
          <div class="plan-option-card__price">$29 / mo</div>
          <ul class="plan-option-card__features">
            <li>5 users</li>
            <li>1 country</li>
            <li>100 properties</li>
          </ul>
          <button
            type="button"
            class="btn btn-secondary w-full mt-2"
            disabled={{or (eq this.company.subscriptionTier 'STARTER') (eq this.company.subscriptionTier 'PRO') this.isUpgrading}}
            {{on "click" (fn this.upgrade "STARTER")}}
          >
            {{if this.isUpgrading "Redirecting…" "Select STARTER"}}
          </button>
        </div>

        <div class="plan-option-card {{if (eq this.company.subscriptionTier 'PRO') 'is-current'}}">
          <div class="plan-option-card__name">PRO</div>
          <div class="plan-option-card__price">$99 / mo</div>
          <ul class="plan-option-card__features">
            <li>Unlimited users</li>
            <li>Unlimited countries</li>
            <li>Unlimited properties</li>
          </ul>
          <button
            type="button"
            class="btn btn-primary w-full mt-2"
            disabled={{or (eq this.company.subscriptionTier 'PRO') this.isUpgrading}}
            {{on "click" (fn this.upgrade "PRO")}}
          >
            {{if this.isUpgrading "Redirecting…" "Select PRO"}}
          </button>
        </div>
      </div>
    </div>
    <div class="modal-actions">
      <button type="button" class="btn btn-secondary" {{on "click" this.closeUpgradeModal}}>Close</button>
    </div>
  </Modal>

  <Modal
    @isOpen={{this.showCancelConfirm}}
    @title="Cancel Subscription"
    @onClose={{this.dismissCancel}}
    @showClose={{true}}
  >
    <p>This will downgrade your plan to <strong>FREE</strong> immediately and remove access to paid features.</p>
    <div class="modal-actions">
      <button type="button" class="btn btn-secondary" {{on "click" this.dismissCancel}}>Keep Plan</button>
      <button
        type="button"
        class="btn btn-danger"
        disabled={{this.isCanceling}}
        {{on "click" this.cancelSubscription}}
      >
        {{if this.isCanceling "Cancelling…" "Yes, Cancel"}}
      </button>
    </div>
  </Modal>

{{else}}
  <div class="flex col gap-4 x-center y-center" style="min-height: 40vh; text-align: center;">
    <Ph @icon="buildings" @size="56px" @color="var(--text-muted)" />
    <div>
      <h3 class="font-xl font-bold">No Company Data</h3>
      <p class="text-muted mt-2">Super Admins are not associated with any company.<br>To view a specific company's settings, impersonate a Company Admin.</p>
    </div>
    <LinkTo @route="team" class="btn btn-primary">
      <Ph @icon="users" /> Go to Team
    </LinkTo>
  </div>
{{/if}}
