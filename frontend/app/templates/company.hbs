{{page-title "Company Settings"}}

<div class="page-header">
  <div class="page-title-section">
    <h2 class="page-title"><Ui::Ph @icon="building-office" @size="28px" />
      Company Settings</h2>
    <p class="page-subtitle">Manage your company information.</p>
  </div>
</div>

{{#if this.company}}
  <div class="plan-banner {{this.planTierClass}}">
    <div>
      <div class="plan-banner__name {{this.planNameClass}}">{{or
          this.company.subscriptionTier
          "FREE"
        }}</div>
      <div class="plan-banner__limits">{{this.planLimits}}</div>
    </div>
    {{#if this.company.subscriptionExpiresAt}}
      <div class="plan-banner__expiry">
        Expires
        {{format-date this.company.subscriptionExpiresAt}}
      </div>
    {{/if}}
  </div>

  {{#if this.isCompanyAdmin}}
    <div class="settings-tabs mb-4">
      <button
        type="button"
        class="settings-tab {{if (eq this.activeTab 'general') 'active'}}"
        {{on "click" (fn this.setTab "general")}}
      >
        General
      </button>
      <button
        type="button"
        class="settings-tab {{if (eq this.activeTab 'billing') 'active'}}"
        data-test-billing-tab
        {{on "click" (fn this.setTab "billing")}}
      >
        Billing
      </button>
      <button
        type="button"
        class="settings-tab {{if (eq this.activeTab 'ai') 'active'}}"
        {{on "click" (fn this.setTab "ai")}}
      >
        AI Settings
      </button>
    </div>
  {{/if}}

  {{#if (eq this.activeTab "ai")}}
    {{#if this.weeklyUsageLabel}}
      <div class="glass-panel p-4 max-w-lg mb-4 text-muted font-sm">
        {{this.weeklyUsageLabel}}
      </div>
    {{/if}}

    <div class="glass-panel p-6 max-w-lg">
      <form aria-label="AI Settings" {{on "submit" this.saveAISettings}}>
        <div class="form-group">
          <label class="form-label" for="company-ai-prompt">AI System Prompt</label>
          <textarea
            id="company-ai-prompt"
            data-test-ai-prompt
            class="form-input"
            rows="10"
            placeholder="Leave empty to use the default prompt"
            {{on "input" this.setAIPrompt}}
          >{{this.aiPrompt}}</textarea>
          <p class="text-muted font-sm">
            This prompt tells the AI how to respond on behalf of your company.
            Leave blank to use the built-in default.
          </p>
        </div>

        {{#if this.aiSuccessMsg}}
          <p class="text-success font-sm">{{this.aiSuccessMsg}}</p>
        {{/if}}
        {{#if this.aiErrorMsg}}
          <p class="text-danger font-sm">{{this.aiErrorMsg}}</p>
        {{/if}}

        <div class="flex gap-3 mt-4">
          <button
            type="submit"
            data-test-save-prompt
            class="btn btn-primary"
            disabled={{this.isSavingAI}}
          >
            {{#if this.isSavingAI}}Saving…{{else}}Save{{/if}}
          </button>
          <button
            type="button"
            data-test-restore-prompt
            class="btn btn-secondary"
            disabled={{this.isSavingAI}}
            {{on "click" this.restoreDefaultPrompt}}
          >
            Restore Default
          </button>
        </div>
      </form>
    </div>
  {{else if (eq this.activeTab "billing")}}
    <div class="glass-panel p-6 max-w-lg" data-test-billing-panel>
      <h3 class="font-lg font-bold mb-4">Plan and Billing</h3>

      {{#if this.billing}}
        {{#if this.isScheduledToCancel}}
          <div class="alert alert-warning mb-4" data-test-cancel-scheduled>
            <div>
              <div class="font-bold">Scheduled to move to the Free plan</div>
              <p class="font-sm mt-1">
                Your paid plan is set to end on
                <strong>{{this.cancelDateLabel}}</strong>. You have already paid
                through that date, so you keep full access until then. It
                switches to Free automatically. Changed your mind? Reactivate
                below.
              </p>
            </div>
          </div>
        {{/if}}
        <div class="billing-plan-card mb-4" data-test-plan-card>
          <div class="flex between x-center">
            <div
              class="font-xl font-bold"
              data-test-plan-name
            >{{this.billing.tier}}</div>
            {{#if this.billing.billingStatus}}
              <span
                class="status-badge status-{{lowercase
                    this.billing.billingStatus
                  }}"
                data-test-billing-status
              >
                {{this.billing.billingStatus}}
              </span>
            {{/if}}
          </div>
          <p class="font-sm text-muted mt-2" data-test-seat-count>
            {{this.seatSummaryLabel}}
          </p>
          {{#if this.seatPriceLabel}}
            <p
              class="font-sm text-muted"
              data-test-seat-price
            >{{this.seatPriceLabel}}</p>
          {{/if}}
          {{#if this.purchasedCurrency}}
            <p class="font-sm text-muted" data-test-billed-currency>
              Billed in {{this.purchasedCurrency}}, locked to your account.
            </p>
          {{/if}}
        </div>

        {{#if this.isFreeTier}}
          {{#if this.paymentCurrencyOptions.length}}
            <div class="mb-3" data-test-currency-select>
              <Ui::FormDropdown
                @label="Select your Payment currency"
                @id="billing-currency"
                @value={{this.selectedCurrency}}
                @onChange={{fn this.setField "selectedCurrency"}}
                @options={{this.paymentCurrencyOptions}}
              />
              <p
                class="font-sm text-muted mt-1"
                data-test-currency-lock-note
              >Locked to your account once you subscribe.</p>
            </div>
          {{/if}}
          <button
            type="button"
            class="btn btn-primary"
            data-test-upgrade-pro
            disabled={{this.isBillingBusy}}
            {{on "click" this.upgradeToPro}}
          >
            {{#if this.isBillingBusy}}Starting checkout...{{else}}Upgrade to Pro{{/if}}
          </button>
          <p class="font-sm text-muted mt-3">
            Every Pro seat adds 5 GB of storage. Need white-label, ERP
            integration, or dedicated infrastructure?
            <a
              href="mailto:info@aalasolutions.com?subject=AALA%20Enterprise"
              data-test-contact-enterprise
            >Contact us about Enterprise</a>.
          </p>
        {{else if this.billing.hasSubscription}}
          {{#if this.isScheduledToCancel}}
            <button
              type="button"
              class="btn btn-primary"
              data-test-reactivate-pro
              disabled={{this.isBillingBusy}}
              {{on "click" this.reactivatePro}}
            >
              {{#if this.isBillingBusy}}Working...{{else}}Reactivate plan{{/if}}
            </button>
          {{else}}
            <button
              type="button"
              class="btn btn-danger"
              data-test-downgrade-free
              disabled={{this.isDowngradeDisabled}}
              {{on "click" this.openDowngradeConfirm}}
            >
              Downgrade to Free
            </button>
            {{#unless this.billing.canDowngradeToFree}}
              <p
                class="font-sm text-muted mt-2"
                data-test-downgrade-blocked-hint
              >
                Downgrading requires exactly 1 active user. You currently have
                {{this.billing.activeUsers}}. Deactivate the other team members
                first.
              </p>
            {{/unless}}
          {{/if}}
        {{else}}
          <p class="font-sm text-muted" data-test-billing-managed>
            Your plan is managed by AALA. Contact support to make changes.
          </p>
        {{/if}}
      {{else}}
        <p class="text-muted" data-test-billing-unavailable>Billing information
          is unavailable right now.</p>
      {{/if}}
    </div>

    {{#if this.isCompanyAdmin}}
      <div class="glass-panel p-6 mt-4" data-test-billing-history-panel>
        <h3 class="font-lg font-bold mb-4">Billing History</h3>
        {{#if this.billingHistory.length}}
          <div class="data-table-wrapper data-table-wrapper--with-pagination">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Amount</th>
                  <th>Status</th>
                  <th>Invoice</th>
                </tr>
              </thead>
              <tbody>
                {{#each this.billingHistory as |record|}}
                  <tr data-test-billing-history-row>
                    <td>{{format-date record.occurredAt "medium"}}</td>
                    <td
                      class="font-bold"
                    >{{format-money record.amount record.currency}}</td>
                    <td>
                      {{#if (eq record.type "payment_succeeded")}}
                        <span
                          class="status-badge status-paid"
                          data-test-history-status
                        >Paid</span>
                      {{else}}
                        <span
                          class="status-badge status-failed"
                          data-test-history-status
                        >Failed</span>
                      {{/if}}
                    </td>
                    <td>
                      {{#if record.hostedInvoiceUrl}}
                        <a
                          href={{record.hostedInvoiceUrl}}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="link"
                          data-test-history-invoice-link
                        >
                          <Ui::Ph @icon="receipt" />
                          View
                        </a>
                      {{else}}
                        <span class="text-muted">&mdash;</span>
                      {{/if}}
                    </td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
          <Ui::Pagination
            @selectId="billing-history-limit"
            @page={{this.billingHistoryPage}}
            @limit={{this.billingHistoryLimit}}
            @total={{this.billingHistoryTotal}}
            @onLimitChange={{this.setBillingHistoryLimit}}
            @onPrevious={{this.billingHistoryPrevious}}
            @onNext={{this.billingHistoryNext}}
          />
        {{else}}
          <p
            class="text-muted"
            data-test-billing-history-empty
          >No payments yet. Invoices appear here after your first charge.</p>
        {{/if}}
      </div>
    {{/if}}

    <ConfirmModal
      @isOpen={{this.showDowngradeConfirm}}
      @title="Downgrade to Free"
      @message="Your subscription will be canceled at the end of the current billing period. Paid features, extra seats, and per-seat storage go away when it ends. Nothing is deleted, but uploads beyond the Free 2 GB quota will be blocked."
      @confirmText="Downgrade to Free"
      @confirmingText="Canceling..."
      @confirmType="btn-danger"
      @cancelText="Keep my plan"
      @isConfirming={{this.isBillingBusy}}
      @onClose={{this.closeDowngradeConfirm}}
      @onConfirm={{this.confirmDowngrade}}
    />
  {{else}}
    <div class="company-settings-grid">
      {{! Left: Company Info }}
      <div class="glass-panel p-6">
        <h3 class="font-lg font-bold mb-4">Company Information</h3>
        <form
          aria-label="Company Information"
          class="flex col gap-4"
          {{on "submit" this.saveCompany}}
        >
          <Ui::FormInput
            @label="Company Name"
            @id="company-name"
            @type="text"
            @value={{or this.formName this.company.name}}
            @onChange={{fn this.setField "formName"}}
            @required={{true}}
            @readonly={{not this.isAdmin}}
          />

          {{#if this.company.adminEmail}}
            <Ui::FormInput
              @label="Admin Email"
              @id="company-email"
              @type="email"
              @value={{this.company.adminEmail}}
              @disabled={{true}}
            />
          {{/if}}

          <Ui::FormInput
            @label="Plan"
            @id="company-plan"
            @type="text"
            @value={{or this.company.subscriptionTier "FREE"}}
            @disabled={{true}}
          />

          {{#unless this.isAdmin}}
            <p class="font-sm text-muted">Only company admins and super admins
              can change these settings.</p>
          {{/unless}}

          {{#if this.errorMsg}}
            <p class="text-danger">{{this.errorMsg}}</p>
          {{/if}}

          {{#if this.storageUsage}}
            <div class="storage-usage-section" data-test-storage-usage>
              <h3 class="font-sm font-bold uppercase text-muted mb-2">Storage
                Usage</h3>
              <p class="font-sm mb-2" data-test-storage-label>
                {{format-bytes this.storageUsage.usedBytes}}
                of
                {{format-bytes this.storageUsage.quotaBytes}}
                used ({{this.storageUsage.percentUsed}}%)
              </p>
              <div class="storage-bar" data-test-storage-bar>
                <div
                  class="storage-bar__fill
                    {{if this.isStorageWarning 'storage-bar__fill-warning'}}"
                  style="width: {{this.storageUsage.percentUsed}}%"
                ></div>
              </div>
              <p class="font-xs text-muted mt-1">
                Tier:
                {{this.storageUsage.tier}}
                /
                {{this.storageUsage.purchasedSeats}}
                {{this.seatLabel}}
              </p>
            </div>
          {{/if}}

          <div class="form-actions">
            <Ui::AppButton
              @variant="primary"
              @buttonType="submit"
              @text="Save Changes"
              @loading={{this.isSaving}}
              @loadingText="Saving..."
              @disabled={{not this.isAdmin}}
            />
          </div>
        </form>
      </div>

      {{! Right: Operating Regions }}
      {{#if this.model.regions.length}}
        <div
          class="glass-panel p-6
            {{unless this.isAdmin 'region-settings-readonly'}}"
          data-test-region-settings
        >
          <h3 class="font-lg font-bold mb-2">Operating Regions</h3>
          <p class="font-sm text-muted mb-4">
            Select regions where your company operates. Your
            {{or this.company.subscriptionTier "FREE"}}
            plan includes
            {{if
              (eq this.maxRegions 999)
              "unlimited regions"
              (if
                (eq this.maxRegions 1)
                "1 region"
                (concat this.maxRegions " regions")
              )
            }}.
          </p>

          {{! Default Region (above the list) }}
          {{#if this.formActiveRegions.length}}
            <div class="mb-4">
              <Ui::FormDropdown
                @label="Default Region"
                @id="default-region"
                @value={{this.formDefaultRegionCode}}
                @onChange={{fn this.setField "formDefaultRegionCode"}}
                @options={{this.activeRegionOptions}}
                @placeholder="Select default region..."
                @disabled={{not this.isAdmin}}
                data-test-default-region
              />
            </div>
          {{/if}}

          <p class="font-sm font-bold text-muted uppercase mb-3">Available
            Regions</p>

          {{#each this.model.groupedRegions as |group|}}
            <div
              class="region-country-group mb-2
                {{unless this.isAdmin 'is-readonly'}}"
              data-test-country-group={{group.country}}
            >
              <button
                type="button"
                class="region-country-header"
                {{on "click" (fn this.toggleCountry group.country)}}
              >
                <span class="country-name">{{group.countryName}}</span>
                <span class="country-meta">
                  {{#let (this.selectedCountInGroup group.regions) as |count|}}
                    {{#if count}}
                      <span class="region-selected-badge">{{count}}
                        selected</span>
                    {{/if}}
                  {{/let}}
                  <span class="region-total">{{group.regions.length}}
                    regions</span>
                </span>
                <Ui::Ph
                  @icon={{if
                    (includes this.expandedCountries group.country)
                    "caret-up"
                    "caret-down"
                  }}
                  @size="16"
                />
              </button>
              {{#if (includes this.expandedCountries group.country)}}
                <div class="region-grid mt-2 mb-2 ml-2">
                  {{#each group.regions as |r|}}
                    <div
                      class="region-checkbox
                        {{unless this.isAdmin 'is-readonly'}}"
                      data-test-region-checkbox={{r.code}}
                    >
                      <input
                        type="checkbox"
                        id={{r.code}}
                        checked={{includes this.formActiveRegions r.code}}
                        disabled={{not this.isAdmin}}
                        {{on "change" (fn this.toggleRegion r.code)}}
                      />
                      <label for={{r.code}} class="region-check-label">
                        {{r.name}}
                        <span class="text-muted font-xs">({{r.currency}})</span>
                      </label>
                    </div>
                  {{/each}}
                </div>
              {{/if}}
            </div>
          {{/each}}
        </div>
      {{/if}}
    </div>
  {{/if}}
{{else}}
  <div
    class="flex col gap-4 x-center y-center"
    style="min-height: 40vh; text-align: center;"
  >
    <Ui::Ph @icon="buildings" @size="56px" @color="var(--text-muted)" />
    <div>
      <h3 class="font-xl font-bold">No Company Data</h3>
      <p class="text-muted mt-2">Super Admins are not associated with any
        company.<br />To view a specific company's settings, impersonate a
        Company Admin.</p>
    </div>
    <LinkTo @route="team" class="btn btn-primary">
      <Ui::Ph @icon="users" />
      Go to Team
    </LinkTo>
  </div>
{{/if}}