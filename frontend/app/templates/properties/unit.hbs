{{page-title
  (if @model.unit (concat "Unit " @model.unit.unitNumber) "Unit Detail")
}}

<div data-test-unit-detail class="flex col gap-6">
  {{! Breadcrumb }}
  <div data-test-breadcrumb class="flex x-center gap-2 font-sm text-muted">
    <LinkTo
      @route="properties"
      data-test-breadcrumb-properties
    >Properties</LinkTo>
    <span>/</span>
    {{#if @model.unit.asset.locality}}
      <LinkTo
        @route="properties.detail"
        @model={{@model.areaId}}
        data-test-breadcrumb-area
      >{{@model.unit.asset.locality.name}}</LinkTo>
      <span>/</span>
    {{/if}}
    {{#if @model.unit.asset}}
      <LinkTo
        @route="properties.detail"
        @model={{@model.areaId}}
      >{{@model.unit.asset.name}}</LinkTo>
      <span>/</span>
    {{/if}}
    <span class="font-bold text-primary">Unit {{@model.unit.unitNumber}}</span>
  </div>

  {{#if @model.unit}}
    {{! Two column: Gallery + Info }}
    <div class="unit-detail-grid">
      {{! Left: Photo gallery }}
      <div class="glass-panel p-6 flex col gap-4">
        <div class="flex between x-center mb-2">
          <h4 class="font-sm font-bold uppercase text-muted">Photos</h4>
          <label
            class="btn btn-primary btn-sm {{if this.isUploading 'disabled'}}"
            data-test-upload-photo-btn
          >
            <Ui::Ph @icon="camera-plus" />
            {{if this.isUploading this.uploadStatus "Add Photo"}}
            <input
              type="file"
              class="sr-only"
              accept="image/jpeg,image/png,image/webp"
              {{on "change" this.uploadPhoto}}
            />
          </label>
        </div>

        {{#if this.isUploading}}
          <div class="upload-progress" data-test-upload-progress>
            <div class="upload-progress-bar">
              <div class="upload-progress-bar__track"></div>
            </div>
          </div>
        {{/if}}

        {{#if @model.media.length}}
          {{#let (object-at @model.media 0) as |primary|}}
            <div class="unit-main-photo" data-test-main-photo>
              <img src={{primary.url}} alt="Unit photo" />
            </div>
          {{/let}}
          <div class="flex gap-2 wrap">
            {{#each @model.media as |media|}}
              <div
                class="unit-thumb {{if media.isPrimary 'unit-thumb-primary'}}"
                data-test-photo-thumb
              >
                <img
                  src={{or media.thumbnailUrl media.url}}
                  alt={{media.fileName}}
                />
                <div class="unit-thumb-actions">
                  {{#unless media.isPrimary}}
                    <button
                      type="button"
                      class="btn-icon"
                      title="Set as primary"
                      {{on "click" (fn this.setPrimaryPhoto media)}}
                    >
                      <Ui::Ph @icon="star" />
                    </button>
                  {{/unless}}
                  <button
                    type="button"
                    class="btn-icon btn-icon-danger"
                    title="Delete"
                    {{on "click" (fn this.openDeletePhoto media)}}
                  >
                    <Ui::Ph @icon="trash" />
                  </button>
                </div>
              </div>
            {{/each}}

            {{#if this.previewUrl}}
              <div
                class="unit-thumb upload-preview-thumb"
                data-test-upload-preview
              >
                <img src={{this.previewUrl}} alt="Uploading preview" />
              </div>
            {{/if}}
          </div>
        {{else if this.previewUrl}}
          <div
            class="unit-main-photo upload-preview-active"
            data-test-upload-preview
          >
            <img src={{this.previewUrl}} alt="Uploading preview" />
          </div>
        {{else}}
          <div class="unit-photo-placeholder" data-test-photo-placeholder>
            <Ui::Ph @icon="image" />
            <p class="text-muted mt-2 font-sm">No photos uploaded yet</p>
          </div>
        {{/if}}
      </div>

      {{! Right: Unit info panel }}
      <div class="flex col gap-4">
        <div class="glass-panel p-6 flex col gap-3">
          <div class="flex between x-center">
            <h2 data-test-unit-title class="font-2xl font-bold">Unit
              {{@model.unit.unitNumber}}</h2>
            <button
              type="button"
              class="btn btn-secondary btn-sm"
              data-test-edit-btn
              {{on "click" this.openEdit}}
            >
              <Ui::Ph @icon="pencil-simple" />
              Edit
            </button>
          </div>

          {{#if @model.unit.asset}}
            <p class="text-muted font-sm">
              {{@model.unit.asset.name}}
              {{#if @model.unit.asset.locality}}
                &middot;
                {{@model.unit.asset.locality.name}}
              {{/if}}
            </p>
          {{/if}}

          {{#if @model.unit.price}}
            <p
              data-test-unit-price
              class="font-2xl font-bold text-success"
            >{{format-currency @model.unit.price}}</p>
          {{/if}}

          {{! Specs row }}
          <div class="flex gap-4 font-sm flex wrap" data-test-unit-specs>
            {{#if @model.unit.bedrooms}}
              <span class="flex x-center gap-1"><Ui::Ph @icon="bed" />
                {{@model.unit.bedrooms}}
                Beds</span>
            {{/if}}
            {{#if @model.unit.bathrooms}}
              <span class="flex x-center gap-1"><Ui::Ph @icon="bathtub" />
                {{@model.unit.bathrooms}}
                Baths</span>
            {{/if}}
            {{#if @model.unit.sqFt}}
              <span class="flex x-center gap-1"><Ui::Ph @icon="ruler" />
                {{format-number @model.unit.sqFt}}
                sqft</span>
            {{/if}}
            {{#if @model.unit.floor}}
              <span class="flex x-center gap-1"><Ui::Ph @icon="stairs" />
                Floor
                {{@model.unit.floor}}</span>
            {{/if}}
          </div>

          {{! Status + Property Type badges }}
          <div class="flex gap-3 x-center" data-test-unit-badges>
            <span
              class="status-badge status-{{@model.unit.status}}"
            >{{capitalize @model.unit.status}}</span>
            {{#if @model.unit.propertyType}}
              <span
                class="type-badge type-{{lowercase @model.unit.propertyType}}"
              >
                {{if
                  (eq @model.unit.propertyType "FOR_SALE")
                  "For Sale"
                  "For Rent"
                }}
              </span>
            {{/if}}
          </div>

          {{! Owner }}
          {{#if @model.unit.owner}}
            <div class="flex x-center gap-2 font-sm" data-test-unit-owner>
              <Ui::Ph @icon="user" />
              <span class="text-muted">Owner:</span>
              <LinkTo
                @route="owners.detail"
                @model={{@model.unit.owner.id}}
                class="text-primary owner-link"
              >
                {{@model.unit.owner.name}}
              </LinkTo>
            </div>
          {{/if}}
        </div>

        {{! Amenities card }}
        {{#if @model.unit.amenities.length}}
          <div class="glass-panel p-5" data-test-amenities-card>
            <h4
              class="font-sm font-bold uppercase text-muted mb-3"
            >Amenities</h4>
            <Unit::AmenitiesPrint @amenities={{@model.unit.amenities}} />
          </div>
        {{/if}}
      </div>
    </div>

    {{! Description }}
    {{#if @model.unit.description}}
      <div class="glass-panel p-6" data-test-description>
        <h4 class="font-md font-bold mb-3"><Ui::Ph @icon="text-align-left" />
          Description</h4>
        <p class="text-muted">{{@model.unit.description}}</p>
      </div>
    {{/if}}

    {{! Lease History }}
    <div class="glass-panel p-6" data-test-lease-history>
      <h4 class="font-md font-bold mb-3"><Ui::Ph @icon="file-text" />
        Lease History</h4>
      {{#if @model.leases.length}}
        <div class="data-table-wrapper">
          <table class="data-table">
            <thead>
              <tr>
                <th>Tenant</th>
                <th>Start</th>
                <th>End</th>
                <th>Rent</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              {{#each @model.leases as |lease|}}
                <tr data-test-lease-row>
                  <td>{{lease.tenantName}}</td>
                  <td>{{format-date lease.startDate}}</td>
                  <td>{{format-date lease.endDate}}</td>
                  <td>{{format-currency lease.monthlyRent}}</td>
                  <td><span
                      class="status-badge status-{{lowercase lease.status}}"
                    >{{lease.status}}</span></td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      {{else}}
        <p class="text-muted font-sm">No lease history for this unit.</p>
      {{/if}}
    </div>
  {{else}}
    <div class="glass-panel p-8 text-center" data-test-unit-not-found>
      <Ui::Ph @icon="warning" />
      <p class="text-muted mt-2">Unit not found.</p>
      <LinkTo @route="properties" class="btn btn-primary mt-4">Back to
        Properties</LinkTo>
    </div>
  {{/if}}
</div>

{{! Edit Modal }}
<Ui::Modal
  @isOpen={{this.showEditModal}}
  @title="Edit Unit"
  @onClose={{this.closeEdit}}
  @showClose={{true}}
>
  <form class="flex col gap-4" {{on "submit" this.save}}>
    <div class="flex gap-4">
      <div class="flex col gap-2 flex-1">
        <Ui::FormInput
          @label="Unit Number"
          @id="u-number"
          @type="text"
          @placeholder="e.g. 101"
          @value={{this.formUnitNumber}}
          @onChange={{fn this.setField "formUnitNumber"}}
          @required={{true}}
          data-test-field-unit-number
        />
      </div>
      <div class="flex col gap-2 flex-1">
        <Ui::FormDropdown
          @label="Status"
          @id="u-status"
          @value={{this.formStatus}}
          @onChange={{fn this.setField "formStatus"}}
          @options={{this.statusOptions}}
          @placeholder="Select status..."
          data-test-field-status
        />
      </div>
    </div>

    <Ui::FormDropdown
      @label="Listing Type"
      @id="u-property-type"
      @value={{this.formPropertyType}}
      @onChange={{fn this.setField "formPropertyType"}}
      @options={{this.propertyTypeOptions}}
      @placeholder="Not Listed"
      data-test-field-property-type
    />

    <div class="flex gap-4">
      <div class="flex col gap-2 flex-1">
        <Ui::FormInput
          @label="Price"
          @id="u-price"
          @type="number"
          @min="0"
          @placeholder="e.g. 150000"
          @value={{this.formPrice}}
          @onChange={{fn this.setField "formPrice"}}
          data-test-field-price
        />
      </div>
      <div class="flex col gap-2 flex-1">
        <Ui::FormInput
          @label="Sq Ft"
          @id="u-sqft"
          @type="number"
          @min="0"
          @placeholder="e.g. 850"
          @value={{this.formSqFt}}
          @onChange={{fn this.setField "formSqFt"}}
          data-test-field-sqft
        />
      </div>
    </div>

    <div class="flex gap-4">
      <div class="flex col gap-2 flex-1">
        <Ui::FormInput
          @label="Bedrooms"
          @id="u-beds"
          @type="number"
          @min="0"
          @placeholder="e.g. 2"
          @value={{this.formBedrooms}}
          @onChange={{fn this.setField "formBedrooms"}}
          data-test-field-bedrooms
        />
      </div>
      <div class="flex col gap-2 flex-1">
        <Ui::FormInput
          @label="Bathrooms"
          @id="u-baths"
          @type="number"
          @min="0"
          @placeholder="e.g. 2"
          @value={{this.formBathrooms}}
          @onChange={{fn this.setField "formBathrooms"}}
          data-test-field-bathrooms
        />
      </div>
    </div>

    <Ui::FormInput
      @label="Floor"
      @id="u-floor"
      @type="number"
      @min="0"
      @placeholder="e.g. 5"
      @value={{this.formFloor}}
      @onChange={{fn this.setField "formFloor"}}
      data-test-field-floor
    />

    <div class="flex col gap-2">
      <label class="font-sm text-muted" for="u-desc">Description</label>
      <textarea
        id="u-desc"
        class="form-input"
        data-test-field-description
        rows="3"
        placeholder="Unit description..."
        {{on "input" (fn this.setField "formDescription")}}
      >{{this.formDescription}}</textarea>
    </div>

    <Ui::FormDropdown
      @label="Owner"
      @id="u-owner"
      @value={{this.formOwnerId}}
      @onChange={{fn this.setField "formOwnerId"}}
      @options={{this.ownerOptions}}
      @placeholder="Unassigned"
      data-test-field-owner
    />

    <div class="flex col gap-2">
      <label class="font-sm text-muted">Amenities</label>
      <div class="amenities-grid" data-test-amenities-picker>
        {{#each this.amenityOptions as |opt|}}
          <button
            type="button"
            class="amenity-chip
              {{if
                (includes this.formAmenities opt.key)
                'amenity-chip-active'
              }}"
            data-test-amenity={{opt.key}}
            {{on "click" (fn this.toggleAmenity opt.key)}}
          >
            <Ui::Ph @icon={{opt.icon}} />
            {{opt.label}}
          </button>
        {{/each}}
      </div>
    </div>

    {{#if this.errorMsg}}
      <p class="font-sm text-danger" data-test-error>{{this.errorMsg}}</p>
    {{/if}}

    <div class="flex gap-3 mt-2">
      <button
        type="button"
        class="btn btn-secondary"
        data-test-cancel-btn
        {{on "click" this.closeEdit}}
      >Cancel</button>
      <button
        type="submit"
        class="btn btn-primary"
        data-test-save-btn
        disabled={{this.isSaving}}
      >
        {{if this.isSaving "Saving..." "Update Unit"}}
      </button>
    </div>
  </form>
</Ui::Modal>

<ConfirmModal
  @isOpen={{this.showDeleteModal}}
  @title="Delete Photo"
  @message="Are you sure you want to delete this photo? This action cannot be undone."
  @confirmText="Delete"
  @cancelText="Cancel"
  @confirmType="btn-danger"
  @isConfirming={{this.isDeleting}}
  @confirmingText="Deleting..."
  @onClose={{this.closeDeleteModal}}
  @onConfirm={{this.confirmDeletePhoto}}
/>