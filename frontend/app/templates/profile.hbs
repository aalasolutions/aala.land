{{page-title "My Profile"}}

<div class="page-header">
  <div class="page-title-section">
    <h2 class="page-title"><Ph @icon="user" @size="28px" /> My Profile</h2>
    <p class="page-subtitle">Manage your account settings.</p>
  </div>
</div>

{{#if this.model}}
  <div class="glass-panel p-6 max-w-lg">
    <form {{on "submit" this.saveProfile}}>
      <div class="form-group">
        <label class="form-label" for="profile-name">Name</label>
        <input
          id="profile-name"
          type="text"
          class="form-input"
          value={{or this.formName this.model.name}}
          {{on "input" (fn this.setField "formName")}}
          required
        />
      </div>

      <div class="form-group">
        <label class="form-label" for="profile-email">Email</label>
        <input
          id="profile-email"
          type="email"
          class="form-input"
          value={{this.model.email}}
          disabled
        />
      </div>

      <div class="form-group">
        <label class="form-label" for="profile-password">New Password</label>
        <input
          id="profile-password"
          type="password"
          class="form-input"
          placeholder="Leave blank to keep current"
          value={{this.formPassword}}
          {{on "input" (fn this.setField "formPassword")}}
        />
      </div>

      <div class="form-group">
        <label class="form-label" for="profile-role">Role</label>
        <input
          id="profile-role"
          type="text"
          class="form-input"
          value={{format-role this.model.role}}
          disabled
        />
      </div>

      <div class="profile-connection-card">
        <div class="profile-connection-heading">
          <div class="profile-connection-icon" aria-hidden="true"></div>
          <div class="profile-connection-text">
            <div class="profile-connection-title">Connect your Google account</div>
            <p class="profile-connection-copy">Use your existing account email to sign in with Google next time.</p>
          </div>
        </div>
        {{#if this.isGoogleLinked}}
          <div class="connected-account">
            <Ph @icon="check-circle" @size="18px" />
            <span>Google account connected</span>
          </div>
        {{else}}
          <div class="profile-google-action google-signin-section {{unless this.isLinkingGoogle 'profile-google-button'}}">
            {{#if this.isLinkingGoogle}}
              <button type="button" class="profile-google-button profile-google-button--loading" disabled>
                <span class="google-spinner"></span>
                Linking...
              </button>
            {{else}}
              <div id="google-link-button" class="google-button-host" {{did-insert this.renderGoogleLinkButton}}></div>
            {{/if}}
          </div>
        {{/if}}
      </div>

      {{#if this.errorMsg}}
        <p class="text-danger">{{this.errorMsg}}</p>
      {{/if}}

      <div class="form-actions">
        <button type="submit" class="btn btn-primary" disabled={{this.isSaving}}>
          {{if this.isSaving "Saving..." "Save Changes"}}
        </button>
      </div>
    </form>
  </div>
{{else}}
  <div class="empty-state">
    <p>Loading profile...</p>
  </div>
{{/if}}
