{{page-title "Page Not Found"}}

<div class="flex col gap-4 x-center y-center" style="min-height: 60vh; text-align: center;">
  <Ph @icon="warning-circle" @size="64px" @color="var(--text-muted)" />
  <div>
    <h2 class="font-3xl font-bold">404</h2>
    <p class="text-muted mt-1">This page doesn't exist or you don't have access to it.</p>
  </div>
  <LinkTo @route="dashboard" class="btn btn-primary">
    <Ph @icon="house" /> Go to Dashboard
  </LinkTo>
</div>
