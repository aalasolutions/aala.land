{{page-title "Companies"}}

<div class="page-header">
  <h1 class="page-title"><Ph @icon="buildings" @size="28px" /> Companies</h1>
  <p class="page-subtitle">Manage subscription plans for all companies.</p>
</div>

<div class="glass-panel p-5">
  <div class="mb-4">
    <input
      type="text"
      class="form-input"
      placeholder="Search companies..."
      value={{this.search}}
      {{on "input" this.setSearch}}
    />
  </div>

  <div class="data-table-wrapper">
    <table class="data-table">
      <thead>
        <tr>
          <th>Company</th>
          <th>Plan</th>
          <th>Users</th>
          <th>Expires</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#each this.filteredCompanies as |company|}}
          <tr>
            <td>{{company.name}}</td>
            <td>
              <span class="plan-badge plan-badge--{{lowercase (or company.subscriptionTier "free")}}">
                {{or company.subscriptionTier "FREE"}}
              </span>
            </td>
            <td>{{company.usersCount}} / {{if (eq company.maxUsers 999) "∞" company.maxUsers}}</td>
            <td>{{if company.subscriptionExpiresAt (format-date company.subscriptionExpiresAt) "—"}}</td>
            <td>
              <button type="button" class="btn btn-secondary btn-xs" {{on "click" (fn this.openEdit company)}}>
                Edit
              </button>
            </td>
          </tr>
        {{else}}
          <tr>
            <td colspan="5" class="text-muted text-center p-4">No companies found.</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
</div>

<Modal
  @isOpen={{if this.editingCompany true false}}
  @title="Edit Plan"
  @onClose={{this.closeEdit}}
  @showClose={{true}}
>
  <div class="flex col gap-4">
    <div>
      <p class="form-label mb-2">Plan</p>
      <div class="flex gap-2">
        {{#each (array "FREE" "STARTER" "PRO") as |tier|}}
          <button
            type="button"
            class="btn {{if (eq this.editTier tier) 'btn-primary' 'btn-secondary'}}"
            {{on "click" (fn this.selectTier tier)}}
          >
            {{tier}}
          </button>
        {{/each}}
      </div>
    </div>
    <div>
      <label class="form-label" for="edit-expiry">Expiry Date (optional)</label>
      <input
        id="edit-expiry"
        type="date"
        class="form-input"
        value={{this.editExpiry}}
        {{on "change" this.setExpiry}}
      />
    </div>
  </div>
  <div class="modal-actions">
    <button type="button" class="btn btn-secondary" {{on "click" this.closeEdit}}>Cancel</button>
    <button type="button" class="btn btn-primary" disabled={{this.isSaving}} {{on "click" this.saveEdit}}>
      {{if this.isSaving "Saving…" "Save"}}
    </button>
  </div>
</Modal>
