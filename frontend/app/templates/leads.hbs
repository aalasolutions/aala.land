{{page-title "Leads"}}

<div data-test-leads-page class="flex col gap-6">
  <div class="flex between x-center">
    <div>
      <h2 class="font-3xl font-bold"><Ph @icon="funnel" @size="28px" /> Lead Pipeline</h2>
      <p class="text-muted mt-1">Track and manage your leads through the pipeline.</p>
    </div>
    <div class="flex gap-3 x-center">
      {{!-- View Toggle --}}
      <div class="view-toggle" data-test-view-toggle>
        <button type="button"
          class="view-toggle-btn {{if (eq this.viewMode 'pipeline') 'active'}}"
          {{on "click" (fn this.setViewMode "pipeline")}}>
          <Ph @icon="squares-four" /> Pipeline
        </button>
        <button type="button"
          class="view-toggle-btn {{if (eq this.viewMode 'temperature') 'active'}}"
          {{on "click" (fn this.setViewMode "temperature")}}>
          <Ph @icon="thermometer" /> Temperature
        </button>
        <button type="button"
          class="view-toggle-btn {{if (eq this.viewMode 'agent') 'active'}}"
          {{on "click" (fn this.setViewMode "agent")}}>
          <Ph @icon="users" /> Agent
        </button>
        <button type="button"
          class="view-toggle-btn {{if (eq this.viewMode 'list') 'active'}}"
          {{on "click" (fn this.setViewMode "list")}}>
          <Ph @icon="list" /> List
        </button>
      </div>
      <button type="button" class="btn btn-primary" data-test-add-lead {{on "click" this.openCreate}}>
        <Ph @icon="plus" /> New Lead
      </button>
    </div>
  </div>

  {{!-- Filter Buttons --}}
  <div class="kanban-filters">
    <button type="button" class="filter-btn {{if (eq this.filterType 'all') 'active'}}" {{on "click" (fn this.setFilter "all")}}>
      All
    </button>
    <button type="button" class="filter-btn {{if (eq this.filterType 'mine') 'active'}}" {{on "click" (fn this.setFilter "mine")}}>
      Assigned to Me
    </button>
    <button type="button" class="filter-btn {{if (eq this.filterType 'others') 'active'}}" {{on "click" (fn this.setFilter "others")}}>
      Others
    </button>
    <button type="button" class="filter-btn {{if (eq this.filterType 'unassigned') 'active'}}" {{on "click" (fn this.setFilter "unassigned")}}>
      Unassigned
    </button>
  </div>

  {{!-- PIPELINE KANBAN VIEW --}}
  {{#if (eq this.viewMode 'pipeline')}}
    <div class="kanban-board kanban-board--pipeline">
      {{#each this.columns as |column|}}
        <div data-test-kanban-column
          data-test-column-status={{column.status}}
          class="kanban-column flex col gap-3"
          role="button"
          draggable="true"
          {{on "dragover" (fn this.handleDragOver column.status)}}
          {{on "drop" (fn this.handleDrop column.status)}}
        >
          <div class="flex between x-center px-3 py-2 rounded-lg bg-surface">
            <span class="font-sm font-bold">{{column.label}}</span>
            <span class="font-xs text-muted">{{column.leads.length}}</span>
          </div>

          {{#each column.leads as |lead|}}
            <div
              data-test-lead-card
              data-test-lead-id={{lead.id}}
              class="glass-panel p-4 flex col gap-2 lead-card-clickable"
              draggable="true"
              {{on "dragstart" (fn this.handleDragStart lead)}}
              {{on "click" (fn this.openDetailModal lead)}}
            >
              <div class="flex between x-center">
                <p class="font-sm font-bold">{{lead.firstName}}{{#if lead.lastName}} {{lead.lastName}}{{/if}}</p>
                <span class="temp-badge temp-{{lowercase lead.temperature}}">{{lead.temperature}}</span>
              </div>
              <div class="flex gap-2 x-center">
                <p class="text-muted font-xs">{{lead.phone}}</p>
                {{#if lead.phone}}
                  <a href={{wa-link lead.phone}} target="_blank" rel="noopener noreferrer" class="wa-link" data-test-wa-link {{on "click" this.stopPropagation}}>
                    <Ph @icon="whatsapp-logo" @size="14px" />
                  </a>
                {{/if}}
              </div>
              <p class="text-muted font-xs">{{lead.email}}</p>
              {{#if lead.property}}
                <p class="text-primary font-xs flex gap-1 x-center"><Ph @icon="buildings" /> {{lead.property.name}}</p>
              {{/if}}
              {{#if lead.unit}}
                <p class="text-info font-xs flex gap-1 x-center"><Ph @icon="house" /> Unit {{lead.unit.unitNumber}}</p>
              {{/if}}
              {{#if lead.assignedAgentName}}
                <p class="assign-badge">{{lead.assignedAgentName}}</p>
              {{/if}}
              <div class="flex between x-center mt-1">
                <span class="font-xs text-muted">{{format-date lead.createdAt}}</span>
                <div class="flex gap-2" {{on "click" this.stopPropagation}}>
                  <button type="button" class="btn btn-secondary btn-xs" {{on "click" (fn this.openEdit lead)}}>
                    Edit
                  </button>
                  <button type="button" class="btn btn-secondary btn-xs" {{on "click" (fn this.openAssignModal lead)}}>
                    Assign
                  </button>
                </div>
              </div>
            </div>
          {{else}}
            <div class="p-4 rounded-xl border border-white@05 text-center">
              <p class="text-muted font-xs">No leads</p>
            </div>
          {{/each}}
        </div>
      {{/each}}
    </div>
  {{/if}}

  {{!-- TEMPERATURE BOARD VIEW --}}
  {{#if (eq this.viewMode 'temperature')}}
    <div data-test-temperature-board class="kanban-board kanban-board--temperature">
      {{#each this.temperatureColumns as |column|}}
        <div data-test-kanban-column
          data-test-column-temp={{column.temperature}}
          class="kanban-column flex col gap-3"
          {{on "dragover" (fn this.handleTempDragOver column.temperature)}}
          {{on "drop" (fn this.handleTempDrop column.temperature)}}
        >
          <div class="flex between x-center px-3 py-2 rounded-lg temp-column-header temp-column-{{lowercase column.temperature}}">
            <span class="font-sm font-bold flex gap-2 x-center">
              <Ph @icon={{column.icon}} /> {{column.label}}
            </span>
            <span class="font-xs temp-column-count">{{column.leads.length}}</span>
          </div>

          {{#each column.leads as |lead|}}
            <div
              data-test-lead-card
              data-test-lead-id={{lead.id}}
              class="glass-panel p-4 flex col gap-2 lead-card-clickable"
              draggable="true"
              {{on "dragstart" (fn this.handleDragStart lead)}}
              {{on "click" (fn this.openDetailModal lead)}}
            >
              <div class="flex between x-center">
                <p class="font-sm font-bold">{{lead.firstName}}{{#if lead.lastName}} {{lead.lastName}}{{/if}}</p>
                <span class="status-badge status-{{lowercase lead.status}}">{{lead.status}}</span>
              </div>
              <div class="flex gap-2 x-center">
                <p class="text-muted font-xs">{{lead.phone}}</p>
                {{#if lead.phone}}
                  <a href={{wa-link lead.phone}} target="_blank" rel="noopener noreferrer" class="wa-link" data-test-wa-link {{on "click" this.stopPropagation}}>
                    <Ph @icon="whatsapp-logo" @size="14px" />
                  </a>
                {{/if}}
              </div>
              <p class="text-muted font-xs">{{lead.email}}</p>
              {{#if lead.property}}
                <p class="text-primary font-xs flex gap-1 x-center"><Ph @icon="buildings" /> {{lead.property.name}}</p>
              {{/if}}
              {{#if lead.assignedAgentName}}
                <p class="assign-badge">{{lead.assignedAgentName}}</p>
              {{/if}}
              <div class="flex between x-center mt-1">
                <span class="font-xs text-muted">{{format-date lead.createdAt}}</span>
                <div class="flex gap-2" {{on "click" this.stopPropagation}}>
                  <button type="button" class="btn btn-secondary btn-xs" {{on "click" (fn this.openEdit lead)}}>
                    Edit
                  </button>
                  <button type="button" class="btn btn-secondary btn-xs" {{on "click" (fn this.openAssignModal lead)}}>
                    Assign
                  </button>
                </div>
              </div>
            </div>
          {{else}}
            <div class="p-4 rounded-xl border border-white@05 text-center">
              <p class="text-muted font-xs">No leads</p>
            </div>
          {{/each}}
        </div>
      {{/each}}
    </div>
  {{/if}}

  {{!-- AGENT BOARD VIEW --}}
  {{#if (eq this.viewMode 'agent')}}
    <div data-test-agent-board class="kanban-board kanban-board--agent">
      {{#each this.agentColumns as |column|}}
        <div data-test-kanban-column
          data-test-column-agent={{or column.agentId "unassigned"}}
          class="kanban-column flex col gap-3"
          {{on "dragover" (fn this.handleAgentDragOver column.agentId)}}
          {{on "drop" (fn this.handleAgentDrop column.agentId)}}
        >
          <div class="flex between x-center px-3 py-2 rounded-lg agent-column-header">
            <span class="font-sm font-bold flex gap-2 x-center">
              <Ph @icon={{if column.agentId "user" "user-minus"}} />
              {{column.agentName}}
            </span>
            <span class="agent-load-count">{{column.leads.length}}</span>
          </div>

          {{!-- Load indicator bar --}}
          <div class="agent-load-bar">
            <div class="agent-load-fill {{if (gt column.leads.length 8) 'load-high' (if (gt column.leads.length 4) 'load-medium' 'load-low')}}"></div>
          </div>

          {{#each column.leads as |lead|}}
            <div
              data-test-lead-card
              data-test-lead-id={{lead.id}}
              class="glass-panel p-4 flex col gap-2 lead-card-clickable"
              draggable="true"
              {{on "dragstart" (fn this.handleDragStart lead)}}
              {{on "click" (fn this.openDetailModal lead)}}
            >
              <div class="flex between x-center">
                <p class="font-sm font-bold">{{lead.firstName}}{{#if lead.lastName}} {{lead.lastName}}{{/if}}</p>
                <span class="temp-badge temp-{{lowercase lead.temperature}}">{{lead.temperature}}</span>
              </div>
              <div class="flex gap-2 x-center">
                <p class="text-muted font-xs">{{lead.phone}}</p>
                {{#if lead.phone}}
                  <a href={{wa-link lead.phone}} target="_blank" rel="noopener noreferrer" class="wa-link" data-test-wa-link {{on "click" this.stopPropagation}}>
                    <Ph @icon="whatsapp-logo" @size="14px" />
                  </a>
                {{/if}}
              </div>
              <span class="status-badge status-{{lowercase lead.status}}">{{lead.status}}</span>
              {{#if lead.property}}
                <p class="text-primary font-xs flex gap-1 x-center"><Ph @icon="buildings" /> {{lead.property.name}}</p>
              {{/if}}
              <div class="flex between x-center mt-1">
                <span class="font-xs text-muted">{{format-date lead.createdAt}}</span>
                <div class="flex gap-2" {{on "click" this.stopPropagation}}>
                  <button type="button" class="btn btn-secondary btn-xs" {{on "click" (fn this.openEdit lead)}}>
                    Edit
                  </button>
                </div>
              </div>
            </div>
          {{else}}
            <div class="p-4 rounded-xl border border-white@05 text-center">
              <p class="text-muted font-xs">No leads</p>
            </div>
          {{/each}}
        </div>
      {{/each}}
    </div>
  {{/if}}

  {{!-- LIST VIEW --}}
  {{#if (eq this.viewMode 'list')}}
    <div class="leads-list-view">
      <table class="data-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Contact</th>
            <th>Status</th>
            <th>Temperature</th>
            <th>Property</th>
            <th>Assigned</th>
            <th>Created</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {{#each this.filteredLeads as |lead|}}
            <tr data-test-lead-row data-test-lead-id={{lead.id}} class="lead-row-clickable" {{on "click" (fn this.openDetailModal lead)}}>
              <td>
                <span class="font-bold">{{lead.firstName}}{{#if lead.lastName}} {{lead.lastName}}{{/if}}</span>
              </td>
              <td>
                <div class="flex col gap-1">
                  <div class="flex gap-2 x-center">
                    <span class="font-xs">{{lead.phone}}</span>
                    {{#if lead.phone}}
                      <a href={{wa-link lead.phone}} target="_blank" rel="noopener noreferrer" class="wa-link" data-test-wa-link {{on "click" this.stopPropagation}}>
                        <Ph @icon="whatsapp-logo" @size="14px" />
                      </a>
                    {{/if}}
                  </div>
                  <span class="font-xs text-muted">{{lead.email}}</span>
                </div>
              </td>
              <td>
                <span class="status-badge status-{{lowercase lead.status}}">{{lead.status}}</span>
              </td>
              <td>
                <span class="temp-badge temp-{{lowercase lead.temperature}}">{{lead.temperature}}</span>
              </td>
              <td>
                {{#if lead.property}}
                  <span>{{lead.property.name}}</span>
                  {{#if lead.unit}}
                    <span class="text-muted font-xs"> - Unit {{lead.unit.unitNumber}}</span>
                  {{/if}}
                {{else}}
                  <span class="text-muted">-</span>
                {{/if}}
              </td>
              <td>
                {{#if lead.assignedAgentName}}
                  <span class="assign-badge-sm">{{lead.assignedAgentName}}</span>
                {{else}}
                  <span class="text-muted">Unassigned</span>
                {{/if}}
              </td>
              <td>
                <span class="font-xs text-muted">{{format-date lead.createdAt}}</span>
              </td>
              <td>
                <div class="flex gap-2" {{on "click" this.stopPropagation}}>
                  <button type="button" class="btn btn-secondary btn-xs" {{on "click" (fn this.openEdit lead)}}>
                    Edit
                  </button>
                  <button type="button" class="btn btn-secondary btn-xs" {{on "click" (fn this.openAssignModal lead)}}>
                    Assign
                  </button>
                </div>
              </td>
            </tr>
          {{else}}
            <tr>
              <td colspan="8" class="text-center text-muted py-8">
                No leads found
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  {{/if}}
</div>

{{!-- Edit Modal --}}
<Modal
  @isOpen={{this.showModal}}
  @title={{if this.editLead "Edit Lead" "New Lead"}}
  @onClose={{this.closeModal}}
  @showClose={{true}}
>
  <form class="flex col gap-4" {{on "submit" this.saveLead}}>
    {{#if this.showRegionField}}
      <FormDropdown @label="Region" @id="lead-region" @value={{this.formRegionCode}} @onChange={{this.setRegionCode}} @options={{this.regionOptions}} @placeholder="Select region..." data-test-region-select />
    {{/if}}
    <div class="flex gap-4">
      <div class="flex-1">
        <FormInput @label="First Name" @id="lead-first-name" @type="text" @placeholder="e.g. Ahmed" @value={{this.formFirstName}} @onChange={{fn this.setField "formFirstName"}} @required={{true}} />
      </div>
      <div class="flex-1">
        <FormInput @label="Last Name" @id="lead-last-name" @type="text" @placeholder="e.g. Al Mansouri" @value={{this.formLastName}} @onChange={{fn this.setField "formLastName"}} />
      </div>
    </div>
    <FormInput @label="Email" @id="lead-email" @type="email" @placeholder="ahmed@example.com" @value={{this.formEmail}} @onChange={{fn this.setField "formEmail"}} />
    <FormInput @label="Phone" @id="lead-phone" @type="text" @placeholder="+971501234567" @value={{this.formPhone}} @onChange={{fn this.setField "formPhone"}} />
    <div class="flex gap-4">
      <div class="flex-1">
        <FormDropdown @label="Status" @id="lead-status" @value={{this.formStatus}} @onChange={{fn this.setField "formStatus"}} @options={{this.statusOptions}} @placeholder="Select status..." />
      </div>
      <div class="flex-1">
        <FormDropdown @label="Temperature" @id="lead-temp" @value={{this.formTemperature}} @onChange={{fn this.setField "formTemperature"}} @options={{this.temperatureOptions}} @placeholder="Select temperature..." />
      </div>
    </div>
    <FormDropdown @label="Property Area" @id="lead-property" @value={{this.formPropertyId}} @onChange={{this.setPropertyId}} @options={{this.propertyOptions}} @placeholder="-- None --" />
    {{#if this.formPropertyId}}
      <FormDropdown @label="Unit" @id="lead-unit" @value={{this.formUnitId}} @onChange={{fn this.setField "formUnitId"}} @options={{this.unitOptions}} @placeholder="-- None --" />
    {{/if}}
    {{#if this.errorMsg}}
      <p class="text-danger">{{this.errorMsg}}</p>
    {{/if}}
    <div class="flex gap-3 mt-2">
      <AppButton @variant="secondary" @text="Cancel" @onClick={{this.closeModal}} />
      <AppButton @variant="primary" @buttonType="submit" @text={{if this.editLead "Update" "Create Lead"}} @loading={{this.isSaving}} @loadingText="Saving..." />
    </div>
  </form>
</Modal>

{{!-- Assign Modal --}}
<Modal
  @isOpen={{this.showAssignModal}}
  @title="Assign Lead"
  @onClose={{this.closeAssignModal}}
  @showClose={{true}}
>
  <form class="flex col gap-4" {{on "submit" this.assignToAgent}}>
    <p class="text-muted">Select an agent to assign <strong>{{this.assignLead.firstName}}</strong> to:</p>
    <FormDropdown @label="Agent" @id="agent-select" @value={{this.selectedAgentId}} @onChange={{fn this.setField "selectedAgentId"}} @options={{this.agentOptions}} @placeholder="-- Select Agent --" />
    <div class="flex gap-3 mt-2">
      <AppButton @variant="secondary" @text="Cancel" @onClick={{this.closeAssignModal}} />
      <AppButton @variant="primary" @buttonType="submit" @text="Assign" />
    </div>
  </form>
</Modal>

{{!-- Lead Detail Modal --}}
<Modal
  @isOpen={{this.showDetailModal}}
  @title={{if this.detailLead (concat this.detailLead.firstName (if this.detailLead.lastName (concat " " this.detailLead.lastName) "")) "Lead Details"}}
  @onClose={{this.closeDetailModal}}
  @showClose={{true}}
  @panelClass="modal-lg"
>
    <div class="flex gap-4 x-center">
      <span class="temp-badge temp-{{lowercase this.detailLead.temperature}}">{{this.detailLead.temperature}}</span>
      <span class="status-badge status-{{lowercase this.detailLead.status}}">{{this.detailLead.status}}</span>
    </div>

    {{!-- Content --}}
    <div class="detail-modal-content flex gap-6">
      {{!-- Left: Lead Info --}}
      <div class="detail-info flex col gap-4">
        <div class="info-section">
          <h4 class="font-sm font-bold text-muted mb-2">Contact Info</h4>
          <div class="flex col gap-2">
            <div class="flex gap-2 x-center">
              <span><Ph @icon="phone" /></span>
              <span>{{or this.detailLead.phone 'N/A'}}</span>
              {{#if this.detailLead.phone}}
                <a href={{wa-link this.detailLead.phone}} target="_blank" rel="noopener noreferrer" class="wa-link" data-test-wa-link title="Open WhatsApp">
                  <Ph @icon="whatsapp-logo" @size="16px" />
                </a>
              {{/if}}
            </div>
            <div class="flex gap-2 x-center">
              <span><Ph @icon="envelope" /></span>
              <span>{{or this.detailLead.email 'N/A'}}</span>
            </div>
            {{#if this.detailLead.whatsappNumber}}
              <div class="flex gap-2 x-center">
                <span><Ph @icon="whatsapp-logo" /></span>
                <a href={{wa-link this.detailLead.whatsappNumber}} target="_blank" rel="noopener noreferrer" class="wa-link-text" data-test-wa-link>
                  {{this.detailLead.whatsappNumber}}
                </a>
              </div>
            {{/if}}
          </div>
        </div>

        <div class="info-section">
          <h4 class="font-sm font-bold text-muted mb-2">Property Interest</h4>
          {{#if this.detailLead.property}}
            <div class="flex gap-2 x-center">
              <span><Ph @icon="buildings" /></span>
              <span>{{this.detailLead.property.name}}</span>
            </div>
            {{#if this.detailLead.unit}}
              <div class="flex gap-2 x-center mt-1">
                <span><Ph @icon="house" /></span>
                <span>Unit {{this.detailLead.unit.unitNumber}}</span>
              </div>
            {{/if}}
          {{else}}
            <span class="text-muted">No property selected</span>
          {{/if}}
        </div>

        <div class="info-section">
          <h4 class="font-sm font-bold text-muted mb-2">Budget</h4>
          {{#if this.detailLead.budgetMin}}
            <span>{{format-currency this.detailLead.budgetMin}}</span>
            {{#if this.detailLead.budgetMax}}
              <span> - {{format-currency this.detailLead.budgetMax}}</span>
            {{/if}}
          {{else}}
            <span class="text-muted">Not specified</span>
          {{/if}}
        </div>

        <div class="info-section">
          <h4 class="font-sm font-bold text-muted mb-2">Notes</h4>
          <p class="text-sm">{{or this.detailLead.notes 'No notes'}}</p>
        </div>

        <div class="info-section">
          <h4 class="font-sm font-bold text-muted mb-2">Source</h4>
          <span>{{or this.detailLead.source 'Unknown'}}</span>
        </div>

        <div class="flex gap-2 mt-2">
          <button type="button" class="btn btn-secondary btn-sm flex-1" {{on "click" (fn this.openEdit this.detailLead)}}>
            Edit
          </button>
          <button type="button" class="btn btn-secondary btn-sm flex-1" {{on "click" (fn this.openAssignModal this.detailLead)}}>
            Assign
          </button>
        </div>
      </div>

      {{!-- Right: Activity Timeline --}}
      <div class="detail-timeline flex-1">
        <h4 class="font-sm font-bold text-muted mb-4">Activity History</h4>
        <div class="activity-timeline flex col gap-3">
          {{#each this.leadActivities as |activity|}}
            <div class="activity-item" data-test-activity-id={{activity.id}}>
              <div class="activity-side">
                <div class="activity-icon">
                  <Ph @icon={{get-activity-icon activity.type}} @size="16px" />
                </div>
                <div class="activity-summary">
                  <span class="activity-type">{{activity.type}}</span>
                  <span class="activity-date">{{format-date-time activity.createdAt}}</span>
                </div>
              </div>
              <div class="activity-content">
                <p class="activity-notes">{{activity.notes}}</p>
                {{#if activity.performedByName}}
                  <p class="activity-meta">by {{activity.performedByName}}</p>
                {{/if}}
              </div>
            </div>
          {{else}}
            <div class="text-center text-muted py-8">
              <p>No activity recorded yet</p>
            </div>
          {{/each}}
        </div>
      </div>
    </div>
</Modal>
