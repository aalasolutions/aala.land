{{page-title "WhatsApp Settings"}}

<div class="page-header">
  <div class="page-title-section">
    <h2 class="page-title">
      <Ph @icon="whatsapp-logo" @size="28px" />
      WhatsApp Settings
    </h2>
    <p class="page-subtitle">Configure AI auto-reply for your company's WhatsApp.</p>
  </div>
</div>

{{#if this.weeklyUsageLabel}}
  <div class="glass-panel p-4 max-w-lg mb-4 text-muted font-sm">
    {{this.weeklyUsageLabel}}
  </div>
{{/if}}

<div class="glass-panel p-6 max-w-lg">
  <form {{on "submit" this.save}}>
    <div class="form-group">
      <label class="form-label" for="wa-ai-prompt">AI System Prompt</label>
      <textarea
        id="wa-ai-prompt"
        class="form-input"
        rows="10"
        placeholder="Leave empty to use the default prompt"
        {{on "input" this.setPrompt}}
      >{{this.aiPrompt}}</textarea>
      <p class="text-muted font-sm">
        This prompt tells the AI how to respond on behalf of your company.
        Leave blank to use the built-in default.
      </p>
    </div>

    {{#if this.successMsg}}
      <p class="text-success font-sm">{{this.successMsg}}</p>
    {{/if}}
    {{#if this.errorMsg}}
      <p class="text-danger font-sm">{{this.errorMsg}}</p>
    {{/if}}

    <div class="flex gap-3 mt-4">
      <button type="submit" class="btn btn-primary" disabled={{this.isSaving}}>
        {{#if this.isSaving}}Saving…{{else}}Save{{/if}}
      </button>
      <button
        type="button"
        class="btn btn-secondary"
        disabled={{this.isSaving}}
        {{on "click" this.restoreDefault}}
      >
        Restore Default
      </button>
    </div>
  </form>
</div>
