{{page-title "Cheques"}}

<div data-test-cheques-page class="flex col gap-6">
  <div class="flex between x-center">
    <div>
      <h2 class="font-3xl font-bold"><Ph @icon="checks" @size="28px" /> Cheque Management</h2>
      <p class="text-muted mt-1">Track post-dated cheques and payment schedules.</p>
    </div>
    <button type="button" class="btn btn-primary" {{on "click" this.openCreate}}>
      <Ph @icon="plus" /> New Cheque
    </button>
  </div>

  <div class="tabs">
    <button type="button" class="tab-btn {{if (eq this.activeTab 'cheques') 'active'}}" {{on "click" (fn this.setTab 'cheques')}}>
      <Ph @icon="list-checks" /> Cheques
    </button>
    <button type="button" class="tab-btn {{if (eq this.activeTab 'schedule') 'active'}}" {{on "click" (fn this.setTab 'schedule')}}>
      <Ph @icon="calendar-check" /> Collection Schedule
    </button>
  </div>

  {{#if (eq this.activeTab "cheques")}}
    <div class="glass-panel p-5">
      {{#if @model.cheques.length}}
        <div class="data-table-wrapper">
          <table class="data-table">
            <thead>
              <tr>
                <th>Cheque #</th>
                <th>Bank</th>
                <th>Account Holder</th>
                <th>Amount</th>
                <th>Due Date</th>
                <th>Type</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {{#each @model.cheques as |cheque|}}
                <tr data-test-cheque-row>
                  <td class="font-bold">{{cheque.chequeNumber}}</td>
                  <td>{{cheque.bankName}}</td>
                  <td>{{cheque.accountHolder}}</td>
                  <td class="font-bold">{{format-currency cheque.amount}}</td>
                  <td>{{cheque.dueDate}}</td>
                  <td><span class="type-badge type-{{lowercase cheque.type}}">{{cheque.type}}</span></td>
                  <td><span class="status-badge status-{{lowercase cheque.status}}">{{cheque.status}}</span></td>
                  <td>
                    <div class="flex gap-2">
                      <button type="button" class="btn btn-secondary btn-xs" {{on "click" (fn this.openEdit cheque)}}>
                        <Ph @icon="pencil-simple" /> Edit
                      </button>
                      {{#unless (eq cheque.status "BOUNCED")}}
                        <button type="button" class="btn btn-danger btn-xs" data-test-bounce {{on "click" (fn this.openBounceModal cheque)}}>
                          <Ph @icon="x-circle" /> Bounce
                        </button>
                      {{/unless}}
                    </div>
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      {{else}}
        <p class="text-muted text-center py-8">No cheques yet. Add your first cheque record.</p>
      {{/if}}
    </div>
  {{/if}}

  {{#if (eq this.activeTab "schedule")}}
    <div class="glass-panel p-5">
      <h4 class="font-lg font-bold mb-4"><Ph @icon="calendar" /> Collection Schedule</h4>
      {{#if @model.collectionSchedule.length}}
        <div class="flex col gap-4">
          {{#each @model.collectionSchedule as |group|}}
            <div class="glass-panel p-4">
              <h5 class="font-sm font-bold uppercase tracking-wider text-muted mb-3">{{group.period}}</h5>
              <div class="flex col gap-2">
                {{#each group.cheques as |cheque|}}
                  <div class="flex between x-center p-3 rounded bg-white@02 border border-white@05">
                    <div>
                      <p class="font-sm font-bold">{{cheque.chequeNumber}} - {{cheque.bankName}}</p>
                      <p class="text-muted font-xs">{{cheque.accountHolder}} - Due: {{cheque.dueDate}}</p>
                    </div>
                    <p class="font-sm font-bold">{{format-currency cheque.amount}}</p>
                  </div>
                {{/each}}
              </div>
              {{#if group.totalAmount}}
                <p class="font-sm font-bold text-right mt-2">Total: {{format-currency group.totalAmount}}</p>
              {{/if}}
            </div>
          {{/each}}
        </div>
      {{else}}
        <p class="text-muted text-center py-8">No upcoming cheques in the collection schedule.</p>
      {{/if}}
    </div>
  {{/if}}
</div>

<Modal
  @isOpen={{this.showModal}}
  @title={{if this.editCheque "Edit Cheque" "New Cheque"}}
  @onClose={{this.closeModal}}
  @showClose={{true}}
>
  <form class="flex col gap-4" {{on "submit" this.saveCheque}}>
      <div class="flex gap-4">
        <div class="flex col gap-2 flex-1">
          <FormInput @label="Cheque Number" @id="chq-number" @type="text" @placeholder="e.g. 000123" @value={{this.formChequeNumber}} @onChange={{fn this.setField "formChequeNumber"}} @required={{true}} />
        </div>
        <div class="flex col gap-2 flex-1">
          <FormDropdown @label="Type" @id="chq-type" @value={{this.formType}} @onChange={{fn this.setField "formType"}} @options={{this.chequeTypeOptions}} @placeholder="Select type..." />
        </div>
      </div>
      <FormInput @label="Bank Name" @id="chq-bank" @type="text" @placeholder="e.g. Emirates NBD" @value={{this.formBankName}} @onChange={{fn this.setField "formBankName"}} @required={{true}} />
      <FormInput @label="Account Holder" @id="chq-holder" @type="text" @placeholder="e.g. Ahmed Al Mansouri" @value={{this.formAccountHolder}} @onChange={{fn this.setField "formAccountHolder"}} @required={{true}} />
      <FormDropdown @label="Property (Unit)" @id="chq-unit" @value={{this.formUnitId}} @onChange={{fn this.setField "formUnitId"}} @options={{this.unitOptions}} @placeholder="No property linked" />
      <div class="flex gap-4">
        <div class="flex col gap-2 flex-1">
          <FormInput @label="Amount" @id="chq-amount" @type="number" @min={{0}} @step={{0.01}} @placeholder="e.g. 8500" @value={{this.formAmount}} @onChange={{fn this.setField "formAmount"}} @required={{true}} />
        </div>
        <div class="flex col gap-2 flex-1">
          <label class="font-sm text-muted" for="chq-due">Due Date *</label>
          <input id="chq-due" type="date"
            class="form-input"
            value={{this.formDueDate}} required {{on "change" (fn this.setField "formDueDate")}} />
        </div>
      </div>
      {{#if this.errorMsg}}
        <p class="font-sm text-danger">{{this.errorMsg}}</p>
      {{/if}}
      <div class="flex gap-3 mt-2">
        <AppButton @variant="secondary" @text="Cancel" @onClick={{this.closeModal}} />
        <AppButton @variant="primary" @buttonType="submit" @text={{if this.editCheque "Update" "Create Cheque"}} @loading={{this.isSaving}} @loadingText="Saving..." />
      </div>
    </form>
</Modal>

<Modal
  @isOpen={{this.showBounceModal}}
  @title="Bounce Cheque"
  @onClose={{this.closeBounceModal}}
  @showClose={{true}}
>
  <p class="text-muted">Mark cheque {{this.bounceChequeItem.chequeNumber}} as bounced?</p>
  <div class="flex col gap-2">
    <label class="font-sm text-muted" for="bounce-reason">Reason (optional)</label>
    <input id="bounce-reason" type="text"
      class="form-input"
      placeholder="e.g. Insufficient funds" value={{this.formBounceReason}} {{on "input" (fn this.setField "formBounceReason")}} />
  </div>
  <div class="flex gap-3">
    <AppButton @variant="secondary" @text="Cancel" @onClick={{this.closeBounceModal}} />
    <AppButton @variant="danger" @text="Confirm Bounce" @onClick={{this.confirmBounce}} />
  </div>
</Modal>
