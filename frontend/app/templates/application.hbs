{{page-title "AALA.LAND"}}

{{#if this.session.isAuthenticated}}
  <div class="app-layout {{if this.sidebarCollapsed 'sidebar-collapsed'}}">
    {{!-- Sidebar --}}
    <aside class="sidebar" data-test-sidebar>
      <div class="sidebar-header">
        <h1 class="brand-title">AALA<span class="brand-dot">.</span>LAND</h1>
        {{#unless this.sidebarCollapsed}}
          <p class="brand-subtitle">Property Management</p>
        {{/unless}}
      </div>

      <nav data-test-sidebar-nav class="sidebar-nav">
        {{!-- Dashboard (direct link) --}}
        <LinkTo @route="dashboard" class="sidebar-link" data-test-nav-dashboard>
          <Ph @icon="gauge" /> <span class="sidebar-label">Dashboard</span>
        </LinkTo>

        {{!-- Properties Group --}}
        <div class="sidebar-group {{if (or (eq this.expandedGroup 'properties') (eq this.activeGroup 'properties')) 'expanded'}}">
          <button type="button" class="sidebar-group-toggle {{if (eq this.activeGroup 'properties') 'sidebar-group-active'}}" {{on "click" (fn this.toggleGroup "properties")}}>
            <Ph @icon="buildings" /> <span class="sidebar-label">Properties</span>
            <Ph @icon="caret-down" class="sidebar-chevron" />
          </button>
          <div class="sidebar-group-items">
            <LinkTo @route="properties" class="sidebar-sublink" data-test-nav-properties>
              <span class="sidebar-label">All Properties</span>
            </LinkTo>
            <LinkTo @route="owners" class="sidebar-sublink" data-test-nav-owners>
              <span class="sidebar-label">Owners</span>
            </LinkTo>
          </div>
        </div>

        {{!-- Leads / CRM Group --}}
        <div class="sidebar-group {{if (or (eq this.expandedGroup 'crm') (eq this.activeGroup 'crm')) 'expanded'}}">
          <button type="button" class="sidebar-group-toggle {{if (eq this.activeGroup 'crm') 'sidebar-group-active'}}" {{on "click" (fn this.toggleGroup "crm")}}>
            <Ph @icon="funnel" /> <span class="sidebar-label">Leads</span>
            <Ph @icon="caret-down" class="sidebar-chevron" />
          </button>
          <div class="sidebar-group-items">
            <LinkTo @route="leads" class="sidebar-sublink" data-test-nav-leads>
              <span class="sidebar-label">Pipeline</span>
            </LinkTo>
            <LinkTo @route="contacts" class="sidebar-sublink" data-test-nav-contacts>
              <span class="sidebar-label">Contacts</span>
            </LinkTo>
          </div>
        </div>

        {{!-- Finance Group --}}
        <div class="sidebar-group {{if (or (eq this.expandedGroup 'finance') (eq this.activeGroup 'finance')) 'expanded'}}">
          <button type="button" class="sidebar-group-toggle {{if (eq this.activeGroup 'finance') 'sidebar-group-active'}}" {{on "click" (fn this.toggleGroup "finance")}}>
            <Ph @icon="currency-circle-dollar" /> <span class="sidebar-label">Finance</span>
            <Ph @icon="caret-down" class="sidebar-chevron" />
          </button>
          <div class="sidebar-group-items">
            <LinkTo @route="leases" class="sidebar-sublink" data-test-nav-leases>
              <span class="sidebar-label">Leases</span>
            </LinkTo>
            <LinkTo @route="financials" class="sidebar-sublink" data-test-nav-financials>
              <span class="sidebar-label">Transactions</span>
            </LinkTo>
            <LinkTo @route="cheques" class="sidebar-sublink" data-test-nav-cheques>
              <span class="sidebar-label">Cheques</span>
            </LinkTo>
            <LinkTo @route="commissions" class="sidebar-sublink" data-test-nav-commissions>
              <span class="sidebar-label">Commissions</span>
            </LinkTo>
          </div>
        </div>

        {{!-- Outreach Group --}}
        <div class="sidebar-group {{if (or (eq this.expandedGroup 'outreach') (eq this.activeGroup 'outreach')) 'expanded'}}">
          <button type="button" class="sidebar-group-toggle {{if (eq this.activeGroup 'outreach') 'sidebar-group-active'}}" {{on "click" (fn this.toggleGroup "outreach")}}>
            <Ph @icon="chats-circle" /> <span class="sidebar-label">Outreach</span>
            <Ph @icon="caret-down" class="sidebar-chevron" />
          </button>
          <div class="sidebar-group-items">
            <LinkTo @route="whatsapp" class="sidebar-sublink" data-test-nav-whatsapp>
              <span class="sidebar-label">WhatsApp</span>
            </LinkTo>
            <LinkTo @route="email-templates" class="sidebar-sublink" data-test-nav-templates>
              <span class="sidebar-label">Email Templates</span>
            </LinkTo>
          </div>
        </div>

        {{!-- Operations Group --}}
        <div class="sidebar-group {{if (or (eq this.expandedGroup 'operations') (eq this.activeGroup 'operations')) 'expanded'}}">
          <button type="button" class="sidebar-group-toggle {{if (eq this.activeGroup 'operations') 'sidebar-group-active'}}" {{on "click" (fn this.toggleGroup "operations")}}>
            <Ph @icon="wrench" /> <span class="sidebar-label">Operations</span>
            <Ph @icon="caret-down" class="sidebar-chevron" />
          </button>
          <div class="sidebar-group-items">
            <LinkTo @route="maintenance" class="sidebar-sublink" data-test-nav-maintenance>
              <span class="sidebar-label">Maintenance</span>
            </LinkTo>
            <LinkTo @route="vendors" class="sidebar-sublink" data-test-nav-vendors>
              <span class="sidebar-label">Vendors</span>
            </LinkTo>
          </div>
        </div>

        {{!-- Reports (direct link) --}}
        <LinkTo @route="reports" class="sidebar-link" data-test-nav-reports>
          <Ph @icon="chart-bar" /> <span class="sidebar-label">Reports</span>
        </LinkTo>

        {{!-- Admin Group (company_admin / super_admin only) --}}
        {{#if this.isAdmin}}
          <div class="sidebar-group {{if (or (eq this.expandedGroup 'admin') (eq this.activeGroup 'admin')) 'expanded'}}">
            <button type="button" class="sidebar-group-toggle {{if (eq this.activeGroup 'admin') 'sidebar-group-active'}}" {{on "click" (fn this.toggleGroup "admin")}}>
              <Ph @icon="gear" /> <span class="sidebar-label">Admin</span>
              <Ph @icon="caret-down" class="sidebar-chevron" />
            </button>
            <div class="sidebar-group-items">
              <LinkTo @route="team" class="sidebar-sublink" data-test-nav-team>
                <span class="sidebar-label">Team</span>
              </LinkTo>
              <LinkTo @route="documents" class="sidebar-sublink" data-test-nav-documents>
                <span class="sidebar-label">Documents</span>
              </LinkTo>
              <LinkTo @route="audit" class="sidebar-sublink" data-test-nav-audit>
                <span class="sidebar-label">Audit Log</span>
              </LinkTo>
            </div>
          </div>
        {{/if}}
      </nav>

      <div class="sidebar-spacer"></div>

      {{!-- Collapse toggle --}}
      <button type="button" class="sidebar-collapse-btn" aria-label="Toggle sidebar" {{on "click" this.toggleSidebar}}>
        <Ph @icon={{if this.sidebarCollapsed "caret-double-right" "caret-double-left"}} />
      </button>
    </aside>

    {{!-- Main Content --}}
    <main class="main-content">
      {{!-- Top Bar --}}
      <header class="topbar">
        <div class="search-box">
          <input
            type="text"
            aria-label="Search"
            placeholder="Search..."
            class="search-input"
          />
        </div>
        <div class="topbar-actions">
          {{#if this.showRegionSwitcher}}
            <div class="region-switcher" data-test-region-switcher>
              <button type="button" class="region-btn" {{on "click" this.toggleRegionDropdown}}>
                <Ph @icon="globe" @size="18px" />
                <span class="region-name">{{this.region.activeRegion.name}}</span>
                <Ph @icon="caret-down" @size="12px" />
              </button>
              {{#if this.showRegionDropdown}}
                <button type="button" class="region-overlay" {{on "click" this.closeRegionDropdown}}></button>
                <div class="region-dropdown" data-test-region-dropdown>
                  {{#each this.region.regions as |r|}}
                    <button type="button" class="region-option {{if (eq r.code this.region.activeRegion.code) 'active'}}" data-test-region-option={{r.code}} {{on "click" (fn this.selectRegion r)}}>
                      <span>{{r.name}}</span>
                      <span class="region-currency-tag">{{r.currency}}</span>
                    </button>
                  {{/each}}
                </div>
              {{/if}}
            </div>
          {{/if}}
          <button type="button" class="notification-bell" aria-label="Notifications" {{on "click" this.toggleNotifications}}>
            <Ph @icon="bell" @size="22px" />
            {{#if this.unreadCount}}
              <span class="notification-badge">{{this.unreadCount}}</span>
            {{/if}}
          </button>
          <LinkTo @route="company" class="topbar-icon-btn" aria-label="Company settings">
            <Ph @icon="building-office" @size="20px" />
          </LinkTo>
          <LinkTo @route="profile" class="topbar-icon-btn" aria-label="My profile">
            <Ph @icon="user" @size="20px" />
          </LinkTo>
          <button
            data-test-logout-button
            type="button"
            class="topbar-icon-btn topbar-logout"
            aria-label="Logout"
            {{on "click" this.logout}}
          >
            <Ph @icon="sign-out" @size="20px" />
          </button>
        </div>
      </header>

      {{!-- Notifications Dropdown --}}
      {{#if this.showNotifications}}
        <button type="button" class="notification-overlay" aria-label="Close notifications" {{on "click" this.closeNotifications}}></button>
        <div class="notification-dropdown">
          <div class="notification-dropdown-header">
            <span class="font-sm font-bold">Notifications</span>
            {{#if this.unreadCount}}
              <button type="button" class="btn-link font-xs" {{on "click" this.markAllRead}}>Mark all read</button>
            {{/if}}
          </div>
          <div class="notification-dropdown-list">
            {{#each this.notifications as |notif|}}
              <button type="button" class="notification-item {{unless notif.isRead 'unread'}}" {{on "click" (fn this.markAsRead notif)}}>
                <div class="flex col gap-1">
                  <span class="font-sm font-bold">{{notif.title}}</span>
                  <span class="font-xs text-muted">{{notif.message}}</span>
                </div>
                {{#unless notif.isRead}}
                  <span class="unread-dot"></span>
                {{/unless}}
              </button>
            {{else}}
              <div class="notification-empty">
                <Ph @icon="bell-slash" @size="24px" @color="var(--text-muted)" />
                <p class="font-xs text-muted mt-2">No notifications</p>
              </div>
            {{/each}}
          </div>
        </div>
      {{/if}}

      {{!-- Route Outlet --}}
      <section class="content-area">
        {{outlet}}
      </section>
    </main>
  </div>
{{else}}
  {{outlet}}
{{/if}}

<ToastContainer />
