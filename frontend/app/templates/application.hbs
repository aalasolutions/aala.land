{{page-title "AALA.LAND"}}

{{#if this.session.isAuthenticated}}
  <div
    class="app-layout
      {{if this.desktopCollapsed 'sidebar-collapsed'}}
      {{if this.sidebarMobileOpen 'sidebar-mobile-open'}}"
  >
    {{! Sidebar }}
    <aside class="sidebar" data-test-sidebar>
      <div class="sidebar-header">
        <img src="/Logo.png" alt="AALA.LAND" class="brand-logo-collapsed" />
        <div class="brand-full">
          <h1 class="brand-title">AALA<span class="brand-dot">.</span>LAND</h1>
          <p class="brand-subtitle">Property Management</p>
        </div>
      </div>

      <nav data-test-sidebar-nav class="sidebar-nav">
        {{! Dashboard (direct link) }}
        <LinkTo @route="dashboard" class="sidebar-link" data-test-nav-dashboard>
          <Ui::Ph @icon="gauge" />
          <span class="sidebar-label">Dashboard</span>
        </LinkTo>

        {{! Properties Group }}
        {{#if this.sidebarGroups.properties}}
          <div
            class="sidebar-group
              {{if
                (or
                  (eq this.expandedGroup 'properties')
                  (eq this.activeGroup 'properties')
                )
                'expanded'
              }}"
          >
            <button
              type="button"
              class="sidebar-group-toggle
                {{if
                  (eq this.activeGroup 'properties')
                  'sidebar-group-active'
                }}"
              {{on "click" (fn this.toggleGroup "properties")}}
            >
              <Ui::Ph @icon="buildings" />
              <span class="sidebar-label">Properties</span>
              <Ui::Ph @icon="caret-down" class="sidebar-chevron" />
            </button>
            <div class="sidebar-group-items">
              <LinkTo
                @route="properties"
                class="sidebar-sublink"
                data-test-nav-properties
              >
                <span class="sidebar-label">All Properties</span>
              </LinkTo>
              <LinkTo
                @route="owners"
                class="sidebar-sublink"
                data-test-nav-owners
              >
                <span class="sidebar-label">Owners</span>
              </LinkTo>
              <LinkTo
                @route="leases"
                class="sidebar-sublink"
                data-test-nav-leases
              >
                <span class="sidebar-label">Leases</span>
              </LinkTo>
            </div>
          </div>
        {{/if}}

        {{! Leads / CRM Group }}
        {{#if this.sidebarGroups.crm}}
          <div
            class="sidebar-group
              {{if
                (or (eq this.expandedGroup 'crm') (eq this.activeGroup 'crm'))
                'expanded'
              }}"
          >
            <button
              type="button"
              class="sidebar-group-toggle
                {{if (eq this.activeGroup 'crm') 'sidebar-group-active'}}"
              {{on "click" (fn this.toggleGroup "crm")}}
            >
              <Ui::Ph @icon="funnel" />
              <span class="sidebar-label">Leads</span>
              <Ui::Ph @icon="caret-down" class="sidebar-chevron" />
            </button>
            <div class="sidebar-group-items">
              <LinkTo
                @route="leads"
                class="sidebar-sublink"
                data-test-nav-leads
              >
                <span class="sidebar-label">Pipeline</span>
              </LinkTo>
              <LinkTo
                @route="contacts"
                class="sidebar-sublink"
                data-test-nav-contacts
              >
                <span class="sidebar-label">Contacts</span>
              </LinkTo>
            </div>
          </div>
        {{/if}}

        {{! Documents (direct link) }}
        {{#if this.sidebarGroups.documents}}
          <LinkTo
            @route="documents"
            class="sidebar-link"
            data-test-nav-documents
          >
            <Ui::Ph @icon="files" />
            <span class="sidebar-label">Documents</span>
          </LinkTo>
        {{/if}}

        {{! Finance Group }}
        {{#if this.sidebarGroups.finance}}
          <div
            class="sidebar-group
              {{if
                (or
                  (eq this.expandedGroup 'finance')
                  (eq this.activeGroup 'finance')
                )
                'expanded'
              }}"
          >
            <button
              type="button"
              class="sidebar-group-toggle
                {{if (eq this.activeGroup 'finance') 'sidebar-group-active'}}"
              {{on "click" (fn this.toggleGroup "finance")}}
            >
              <Ui::Ph @icon="currency-circle-dollar" />
              <span class="sidebar-label">Finance</span>
              <Ui::Ph @icon="caret-down" class="sidebar-chevron" />
            </button>
            <div class="sidebar-group-items">
              <LinkTo
                @route="financials"
                class="sidebar-sublink"
                data-test-nav-financials
              >
                <span class="sidebar-label">Transactions</span>
              </LinkTo>
              <LinkTo
                @route="cheques"
                class="sidebar-sublink"
                data-test-nav-cheques
              >
                <span class="sidebar-label">Cheques</span>
              </LinkTo>
              <LinkTo
                @route="commissions"
                class="sidebar-sublink"
                data-test-nav-commissions
              >
                <span class="sidebar-label">Commissions</span>
              </LinkTo>
            </div>
          </div>
        {{/if}}

        {{! WhatsApp (direct link) }}
        {{#if this.sidebarGroups.outreach}}
          <LinkTo @route="whatsapp" class="sidebar-link" data-test-nav-whatsapp>
            <Ui::Ph @icon="whatsapp-logo" />
            <span class="sidebar-label">WhatsApp</span>
          </LinkTo>
        {{/if}}

        {{! Operations Group }}
        {{#if this.sidebarGroups.operations}}
          <div
            class="sidebar-group
              {{if
                (or
                  (eq this.expandedGroup 'operations')
                  (eq this.activeGroup 'operations')
                )
                'expanded'
              }}"
          >
            <button
              type="button"
              class="sidebar-group-toggle
                {{if
                  (eq this.activeGroup 'operations')
                  'sidebar-group-active'
                }}"
              {{on "click" (fn this.toggleGroup "operations")}}
            >
              <Ui::Ph @icon="wrench" />
              <span class="sidebar-label">Operations</span>
              <Ui::Ph @icon="caret-down" class="sidebar-chevron" />
            </button>
            <div class="sidebar-group-items">
              <LinkTo
                @route="maintenance"
                class="sidebar-sublink"
                data-test-nav-maintenance
              >
                <span class="sidebar-label">Maintenance</span>
              </LinkTo>
              <LinkTo
                @route="vendors"
                class="sidebar-sublink"
                data-test-nav-vendors
              >
                <span class="sidebar-label">Vendors</span>
              </LinkTo>
            </div>
          </div>
        {{/if}}

        {{! Reports (direct link) }}
        {{#if this.sidebarGroups.reports}}
          <LinkTo @route="reports" class="sidebar-link" data-test-nav-reports>
            <Ui::Ph @icon="chart-bar" />
            <span class="sidebar-label">Reports</span>
          </LinkTo>
        {{/if}}

        {{! Team (direct link for Company Admin and Admin) }}
        {{#if this.sidebarGroups.team}}
          {{#unless this.isSuperAdmin}}
            <LinkTo @route="team" class="sidebar-link" data-test-nav-team>
              <Ui::Ph @icon="users-three" />
              <span class="sidebar-label">Team</span>
            </LinkTo>
          {{/unless}}
        {{/if}}

        {{! Admin Group (Super Admin only) }}
        {{#if this.sidebarGroups.admin}}
          <div
            class="sidebar-group
              {{if
                (or
                  (eq this.expandedGroup 'admin') (eq this.activeGroup 'admin')
                )
                'expanded'
              }}"
          >
            <button
              type="button"
              class="sidebar-group-toggle
                {{if (eq this.activeGroup 'admin') 'sidebar-group-active'}}"
              {{on "click" (fn this.toggleGroup "admin")}}
            >
              <Ui::Ph @icon="gear" />
              <span class="sidebar-label">Admin</span>
              <Ui::Ph @icon="caret-down" class="sidebar-chevron" />
            </button>
            <div class="sidebar-group-items">
              <LinkTo
                @route="admin.overview"
                class="sidebar-sublink"
                data-test-nav-overview
              >
                <span class="sidebar-label">Overview</span>
              </LinkTo>
              <LinkTo
                @route="admin.companies"
                class="sidebar-sublink"
                data-test-nav-companies
              >
                <span class="sidebar-label">Companies</span>
              </LinkTo>
              <LinkTo
                @route="admin.marketers"
                class="sidebar-sublink"
                data-test-nav-marketers
              >
                <span class="sidebar-label">Marketers</span>
              </LinkTo>
              <LinkTo @route="team" class="sidebar-sublink" data-test-nav-team>
                <span class="sidebar-label">Team</span>
              </LinkTo>
              <LinkTo
                @route="documents"
                class="sidebar-sublink"
                data-test-nav-documents
              >
                <span class="sidebar-label">Documents</span>
              </LinkTo>
              <LinkTo
                @route="audit"
                class="sidebar-sublink"
                data-test-nav-audit
              >
                <span class="sidebar-label">Audit Log</span>
              </LinkTo>
              <LinkTo
                @route="admin.system"
                class="sidebar-sublink"
                data-test-nav-system
              >
                <span class="sidebar-label">System</span>
              </LinkTo>
            </div>
          </div>
        {{/if}}
      </nav>

      <div class="sidebar-spacer"></div>

      {{! Collapse toggle }}
      <button
        type="button"
        class="sidebar-collapse-btn"
        aria-label="Toggle sidebar"
        {{on "click" this.toggleSidebar}}
      >
        <Ui::Ph
          @icon={{if
            this.sidebarRailed
            "caret-double-right"
            "caret-double-left"
          }}
        />
      </button>
    </aside>

    {{#if this.sidebarMobileOpen}}
      <button
        type="button"
        class="sidebar-backdrop"
        aria-label="Close menu"
        data-test-sidebar-backdrop
        {{on "click" this.closeMobileSidebar}}
      ></button>
    {{/if}}

    {{! Main Content }}
    <main class="main-content">
      {{#if this.session.isImpersonating}}
        <div class="impersonation-banner" data-test-impersonation-banner>
          <span>
            Impersonating
            <strong>{{this.session.data.authenticated.user.name}}</strong>
            ({{this.session.data.authenticated.user.email}})
          </span>
          <button
            type="button"
            class="btn btn-warning btn-sm"
            data-test-exit-impersonation
            {{on "click" this.exitImpersonation}}
          >
            Exit Impersonation
          </button>
        </div>
      {{/if}}
      <TenantLockBanner @lockState={{this.session.lockState}} />
      {{! Top Bar }}
      <header class="topbar">
        <div class="search-box">
          <input
            type="text"
            autocomplete="off"
            aria-label="Search"
            placeholder="Search..."
            class="search-input"
            aria-autocomplete="list"
            aria-haspopup="listbox"
            aria-expanded={{if this.showSearchDropdown "true" "false"}}
            aria-controls="search-results"
            aria-activedescendant={{this.activeSearchResultId}}
            value={{this.searchQuery}}
            {{on "input" this.onSearchInput}}
            {{on "keydown" this.onSearchKeydown}}
          />
          {{#if this.showSearchDropdown}}
            <SearchDropdown
              @results={{this.searchResults}}
              @isSearching={{this.isSearching}}
              @onSelect={{this.onSearchSelect}}
              @activeIndex={{this.activeSearchIndex}}
            />
          {{/if}}
        </div>
        {{#if this.showSearchDropdown}}
          <div
            class="search-overlay"
            tabindex="-1"
            aria-hidden="true"
            {{on "click" this.closeSearch}}
          ></div>
        {{/if}}
        <div class="topbar-actions">
          {{#if this.showRegionSwitcher}}
            <div class="region-switcher" data-test-region-switcher>
              <button
                type="button"
                class="region-btn"
                {{on "click" this.toggleRegionDropdown}}
              >
                <Ui::Ph @icon="globe" @size="18px" />
                <span
                  class="region-name"
                >{{this.region.activeRegion.name}}</span>
                <Ui::Ph @icon="caret-down" @size="12px" />
              </button>
              {{#if this.showRegionDropdown}}
                <button
                  type="button"
                  class="region-overlay"
                  {{on "click" this.closeRegionDropdown}}
                ></button>
                <div class="region-dropdown" data-test-region-dropdown>
                  {{#each this.groupedRegions as |grp|}}
                    <div
                      class="region-group-label"
                      data-test-region-group={{grp.countryName}}
                    >{{grp.countryName}}</div>
                    {{#each grp.regions as |r|}}
                      <button
                        type="button"
                        class="region-option
                          {{if
                            (eq r.code this.region.activeRegion.code)
                            'active'
                          }}"
                        data-test-region-option={{r.code}}
                        {{on "click" (fn this.selectRegion r)}}
                      >
                        <span>{{r.name}}</span>
                        <span class="region-currency-tag">{{r.currency}}</span>
                      </button>
                    {{/each}}
                  {{/each}}
                </div>
              {{/if}}
            </div>
          {{else if this.showRegionLabel}}
            <div class="region-label" data-test-region-label>
              <Ui::Ph @icon="globe" @size="18px" />
              <span class="region-name">{{this.region.activeRegion.name}}</span>
            </div>
          {{/if}}
          <button
            type="button"
            class="notification-bell"
            aria-label="Notifications"
            {{on "click" this.toggleNotifications}}
          >
            <Ui::Ph @icon="bell" @size="22px" />
            {{#if this.unreadCount}}
              <span class="notification-badge">{{this.unreadCount}}</span>
            {{/if}}
          </button>
          {{#unless this.isSuperAdmin}}
            <LinkTo
              @route="company"
              class="topbar-icon-btn"
              aria-label="Company settings"
            >
              <Ui::Ph @icon="building-office" @size="20px" />
            </LinkTo>
          {{/unless}}
          <LinkTo
            @route="profile"
            class="topbar-icon-btn"
            aria-label="My profile"
          >
            <Ui::Ph @icon="user" @size="20px" />
          </LinkTo>
          <button
            data-test-logout-button
            type="button"
            class="topbar-icon-btn topbar-logout"
            aria-label="Logout"
            {{on "click" this.logout}}
          >
            <Ui::Ph @icon="sign-out" @size="20px" />
          </button>
        </div>
      </header>

      {{! Notifications Dropdown }}
      {{#if this.showNotifications}}
        <button
          type="button"
          class="notification-overlay"
          aria-label="Close notifications"
          {{on "click" this.closeNotifications}}
        ></button>
        <div class="notification-dropdown">
          <div class="notification-dropdown-header">
            <span class="font-sm font-bold">Notifications</span>
            {{#if this.unreadCount}}
              <button
                type="button"
                class="btn-link font-xs"
                {{on "click" this.markAllRead}}
              >Mark all read</button>
            {{/if}}
          </div>
          <div class="notification-dropdown-list">
            {{#each this.notifications as |notif|}}
              <button
                type="button"
                class="notification-item {{unless notif.isRead 'unread'}}"
                {{on "click" (fn this.markAsRead notif)}}
              >
                <div class="notification-icon {{notif.type}}">
                  <Ui::Ph
                    @icon={{get-notification-icon notif.type}}
                    @size="18px"
                  />
                </div>
                <div class="notification-content">
                  <span class="notification-title">{{notif.title}}</span>
                  <span class="notification-message">{{notif.message}}</span>
                  <span class="notification-time">{{format-date-time
                      notif.createdAt
                    }}</span>
                </div>
                {{#unless notif.isRead}}
                  <span class="unread-dot"></span>
                {{/unless}}
              </button>
            {{else}}
              <div class="notification-empty">
                <Ui::Ph
                  @icon="bell-slash"
                  @size="24px"
                  @color="var(--text-muted)"
                />
                <p class="font-xs text-muted mt-2">No notifications</p>
              </div>
            {{/each}}
          </div>
        </div>
      {{/if}}

      {{! Route Outlet }}
      <section class="content-area">
        {{outlet}}
      </section>
    </main>
  </div>
{{else}}
  {{outlet}}
{{/if}}

<Ui::ToastContainer />

<ConfirmModal
  @isOpen={{this.showLogoutModal}}
  @title="Logout"
  @message="Are you sure you want to logout?"
  @confirmText="Logout"
  @cancelText="Cancel"
  @confirmType="btn-danger"
  @onClose={{this.closeLogoutModal}}
  @onConfirm={{this.confirmLogout}}
/>