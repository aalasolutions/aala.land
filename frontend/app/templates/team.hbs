{{page-title "Team"}}

<div data-test-team-page class="flex col gap-6">
  <div class="flex between x-center">
    <div>
      <h2 class="font-3xl font-bold"><Ph @icon="users-three" @size="28px" /> Team</h2>
      <p class="text-muted mt-1">Manage your team members and their roles.</p>
    </div>
    <div class="flex gap-3">
      <button type="button" class="btn btn-secondary" data-test-invite-member {{on "click" this.openInvite}}>
        <Ph @icon="envelope" /> Invite
      </button>
      <button type="button" class="btn btn-primary" data-test-add-member {{on "click" this.openCreate}}>
        <Ph @icon="plus" /> Add Member
      </button>
    </div>
  </div>

  <div class="glass-panel p-5">
    {{#if this.model.users.length}}
      <div class="data-table-wrapper data-table-wrapper--with-pagination">
        <table class="data-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Role</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {{#each this.model.users as |user|}}
              <tr data-test-user-id={{user.id}}>
                <td class="font-bold">{{user.name}}</td>
                <td class="text-muted">{{user.email}}</td>
                <td><span class="status-badge">{{format-role user.role}}</span></td>
                <td>
                  {{#if user.isActive}}
                    <span class="status-badge status-completed">Active</span>
                  {{else}}
                    <span class="status-badge status-pending">Inactive</span>
                  {{/if}}
                </td>
                <td>
                  <div class="flex gap-2">
                    <button type="button" class="btn btn-secondary btn-xs" data-test-edit-user {{on "click" (fn this.openEdit user)}}>
                      <Ph @icon="pencil-simple" /> Edit
                    </button>
                    <button type="button" class="btn btn-danger btn-xs" data-test-delete-user {{on "click" (fn this.openDelete user)}}>
                      <Ph @icon="trash" /> Remove
                    </button>
                  </div>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>

      <Pagination
        @selectId="team-limit"
        @page={{this.page}}
        @limit={{this.limit}}
        @total={{@model.total}}
        @onLimitChange={{this.setLimit}}
        @onPrevious={{this.goToPreviousPage}}
        @onNext={{this.goToNextPage}}
      />
    {{else}}
      <p class="text-muted text-center py-8">No team members yet. Add your first team member to get started.</p>
    {{/if}}
  </div>
</div>

<Modal
  @isOpen={{this.showModal}}
  @title={{if this.editUser "Edit Team Member" "Add Team Member"}}
  @onClose={{this.closeModal}}
  @showClose={{true}}
>
  <form class="flex col gap-4" {{on "submit" this.saveUser}}>
    <FormInput @label="Name" @id="t-name" @type="text" @value={{this.formName}} @onChange={{fn this.setField "formName"}} @required={{true}} data-test-input-name />

    <FormInput @label="Email" @id="t-email" @type="email" @value={{this.formEmail}} @onChange={{fn this.setField "formEmail"}} @required={{true}} data-test-input-email />

    {{#unless this.editUser}}
      <FormInput @label="Password" @id="t-password" @type="password" @value={{this.formPassword}} @onChange={{fn this.setField "formPassword"}} @required={{true}} data-test-input-password />
    {{/unless}}

    <div class="flex col gap-2">
      <FormDropdown @label="Role" @id="t-role" @value={{this.formRole}} @onChange={{fn this.setField "formRole"}} @options={{this.roles}} @placeholder="Select role..." data-test-input-role />
    </div>

    {{#if this.errorMsg}}
      <p class="font-sm text-danger" data-test-error>{{this.errorMsg}}</p>
    {{/if}}

    <div class="flex gap-3 mt-2">
      <AppButton @variant="secondary" @text="Cancel" @onClick={{this.closeModal}} />
      <AppButton @variant="primary" @buttonType="submit" @text={{if this.editUser "Update" "Create"}} @loading={{this.isSaving}} @loadingText="Saving..." />
    </div>
  </form>
</Modal>

<Modal
  @isOpen={{this.showInviteModal}}
  @title="Invite Team Member"
  @onClose={{this.closeInvite}}
  @showClose={{true}}
>
  <p class="text-muted font-sm">Send an invitation with a temporary password. The new member will receive login credentials.</p>
  <form class="flex col gap-4" {{on "submit" this.sendInvite}}>
    <div class="flex gap-4">
      <div class="flex col gap-2 flex-1">
        <FormInput @label="First Name" @id="i-fname" @type="text" @placeholder="e.g. Jane" @value={{this.inviteFirstName}} @onChange={{fn this.setField "inviteFirstName"}} @required={{true}} data-test-invite-first />
      </div>
      <div class="flex col gap-2 flex-1">
        <FormInput @label="Last Name" @id="i-lname" @type="text" @placeholder="e.g. Smith" @value={{this.inviteLastName}} @onChange={{fn this.setField "inviteLastName"}} @required={{true}} data-test-invite-last />
      </div>
    </div>

    <FormInput @label="Email" @id="i-email" @type="email" @placeholder="e.g. jane@company.com" @value={{this.inviteEmail}} @onChange={{fn this.setField "inviteEmail"}} @required={{true}} data-test-invite-email />

    <div class="flex col gap-2">
      <FormDropdown @label="Role" @id="i-role" @value={{this.inviteRole}} @onChange={{fn this.setField "inviteRole"}} @options={{this.roles}} @placeholder="Select role..." data-test-invite-role />
    </div>

    {{#if this.inviteErrorMsg}}
      <p class="font-sm text-danger">{{this.inviteErrorMsg}}</p>
    {{/if}}

    <div class="flex gap-3 mt-2">
      <button type="button" class="btn btn-secondary" {{on "click" this.closeInvite}}>Cancel</button>
      <button type="submit" class="btn btn-primary" disabled={{this.isInviting}} data-test-send-invite>
        {{if this.isInviting "Sending..." "Send Invitation"}}
      </button>
    </div>
  </form>
</Modal>

<ConfirmModal
  @isOpen={{this.showDeleteModal}}
  @title="Remove Team Member"
  @message="Are you sure you want to remove {{this.userToDelete.name}}? This action cannot be undone."
  @confirmText="Remove"
  @cancelText="Cancel"
  @confirmType="btn-danger"
  @isConfirming={{this.isDeleting}}
  @confirmingText="Removing..."
  @onClose={{this.closeDeleteModal}}
  @onConfirm={{this.confirmDelete}}
/>
