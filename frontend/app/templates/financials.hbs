{{page-title "Financials"}}

<div data-test-financials-page class="flex col gap-6">
  <div class="flex between x-center">
    <div>
      <h2 class="font-3xl font-bold"><Ph @icon="currency-dollar" @size="28px" /> Financial Overview</h2>
      <p class="text-muted mt-1">Transactions, revenue, and payment tracking.</p>
    </div>
    <button type="button" class="btn btn-primary" {{on "click" this.openCreate}}>
      <Ph @icon="plus" /> New Transaction
    </button>
  </div>

  {{#if @model.summary}}
    <div class="grid cols-3 gap-4">
      <div data-test-summary="total-income" class="glass-panel p-5">
        <p class="text-muted font-sm uppercase tracking-wider mb-1"><Ph @icon="trend-up" /> Total Income</p>
        <h3 class="font-3xl font-bold text-success">AED {{format-number @model.summary.totalIncome}}</h3>
      </div>
      <div data-test-summary="total-expense" class="glass-panel p-5">
        <p class="text-muted font-sm uppercase tracking-wider mb-1"><Ph @icon="trend-down" /> Total Expenses</p>
        <h3 class="font-3xl font-bold text-danger">AED {{format-number @model.summary.totalExpense}}</h3>
      </div>
      <div data-test-summary="net" class="glass-panel p-5">
        <p class="text-muted font-sm uppercase tracking-wider mb-1"><Ph @icon="scale" /> Net Balance</p>
        <h3 class="font-3xl font-bold">AED {{format-number @model.summary.net}}</h3>
      </div>
    </div>
  {{/if}}

  {{#if @model.depositReminders.length}}
    <div class="glass-panel p-5">
      <h4 class="font-lg font-bold mb-3"><Ph @icon="bell-ringing" /> Deposit Reminders</h4>
      <div class="flex col gap-2">
        {{#each @model.depositReminders as |reminder|}}
          <div class="flex between x-center p-3 rounded bg-white@02 border border-white@05">
            <div>
              <p class="font-sm font-bold">{{reminder.description}}</p>
              <p class="text-muted font-xs">Due: {{reminder.dueDate}} - {{reminder.category}}</p>
            </div>
            <p class="font-sm font-bold">AED {{format-number reminder.amount}}</p>
          </div>
        {{/each}}
      </div>
    </div>
  {{/if}}

  <div class="glass-panel p-5">
    <div class="flex between x-center mb-4">
      <h4 class="font-lg font-bold">Transactions</h4>
      <div class="tabs">
        <button type="button" class="tab-btn {{if (eq this.activeTab 'all') 'active'}}" {{on "click" (fn this.setTab 'all')}}>All</button>
        <button type="button" class="tab-btn {{if (eq this.activeTab 'INCOME') 'active'}}" {{on "click" (fn this.setTab 'INCOME')}}>Income</button>
        <button type="button" class="tab-btn {{if (eq this.activeTab 'EXPENSE') 'active'}}" {{on "click" (fn this.setTab 'EXPENSE')}}>Expenses</button>
      </div>
    </div>
    {{#if this.filteredTransactions.length}}
      <div class="data-table-wrapper">
        <table class="data-table">
          <thead>
            <tr>
              <th>Description</th>
              <th>Category</th>
              <th>Payment</th>
              <th>Amount</th>
              <th>Status</th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {{#each this.filteredTransactions as |tx|}}
              <tr data-test-transaction>
                <td>{{tx.description}}</td>
                <td><span class="type-badge">{{tx.category}}</span></td>
                <td>{{tx.paymentMethod}}</td>
                <td class="font-bold {{if (eq tx.type 'INCOME') 'text-success' 'text-danger'}}">
                  {{if (eq tx.type 'INCOME') "+" "-"}}AED {{format-number tx.amount}}
                </td>
                <td><span class="status-badge status-{{lowercase tx.status}}">{{tx.status}}</span></td>
                <td class="font-xs">{{tx.transactionDate}}</td>
                <td>
                  <button type="button" class="btn btn-secondary btn-xs" {{on "click" (fn this.openEdit tx)}}>
                    <Ph @icon="pencil-simple" /> Edit
                  </button>
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{else}}
      <p class="text-muted text-center py-4">
        {{if (eq this.activeTab 'INCOME') 'No income transactions.' (if (eq this.activeTab 'EXPENSE') 'No expense transactions.' 'No transactions yet.')}}
      </p>
    {{/if}}
  </div>
</div>

{{#if this.showModal}}
  <button type="button" class="modal-backdrop" aria-label="Close modal" {{on "click" this.closeModal}}></button>
  <div class="modal-panel glass-panel p-8 flex col gap-6" role="dialog">
    <div class="flex between x-center">
      <h3 class="font-xl font-bold">{{if this.editTransaction "Edit Transaction" "New Transaction"}}</h3>
      <button type="button" class="text-muted font-lg px-2" {{on "click" this.closeModal}}>x</button>
    </div>
    <form class="flex col gap-4" {{on "submit" this.saveTx}}>
      <div class="flex gap-4">
        <div class="flex col gap-2 flex-1">
          <label class="font-sm text-muted" for="tx-type">Type *</label>
          <select id="tx-type" class="form-input" {{on "change" (fn this.setField "formType")}}>
            <option value="INCOME" selected={{eq this.formType "INCOME"}}>Income</option>
            <option value="EXPENSE" selected={{eq this.formType "EXPENSE"}}>Expense</option>
          </select>
        </div>
        <div class="flex col gap-2 flex-1">
          <label class="font-sm text-muted" for="tx-category">Category</label>
          <select id="tx-category" class="form-input" {{on "change" (fn this.setField "formCategory")}}>
            <option value="RENT" selected={{eq this.formCategory "RENT"}}>Rent</option>
            <option value="SALE" selected={{eq this.formCategory "SALE"}}>Sale</option>
            <option value="DEPOSIT" selected={{eq this.formCategory "DEPOSIT"}}>Deposit</option>
            <option value="MAINTENANCE" selected={{eq this.formCategory "MAINTENANCE"}}>Maintenance</option>
            <option value="COMMISSION" selected={{eq this.formCategory "COMMISSION"}}>Commission</option>
            <option value="OTHER" selected={{eq this.formCategory "OTHER"}}>Other</option>
          </select>
        </div>
      </div>
      <div class="flex gap-4">
        <div class="flex col gap-2 flex-1">
          <label class="font-sm text-muted" for="tx-amount">Amount (AED) *</label>
          <input id="tx-amount" type="number" min="0" step="0.01"
            class="form-input"
            placeholder="e.g. 15000" value={{this.formAmount}} required {{on "input" (fn this.setField "formAmount")}} />
        </div>
        <div class="flex col gap-2 flex-1">
          <label class="font-sm text-muted" for="tx-payment">Payment Method</label>
          <select id="tx-payment" class="form-input" {{on "change" (fn this.setField "formPaymentMethod")}}>
            <option value="CASH" selected={{eq this.formPaymentMethod "CASH"}}>Cash</option>
            <option value="CHEQUE" selected={{eq this.formPaymentMethod "CHEQUE"}}>Cheque</option>
            <option value="BANK_TRANSFER" selected={{eq this.formPaymentMethod "BANK_TRANSFER"}}>Bank Transfer</option>
            <option value="CREDIT_CARD" selected={{eq this.formPaymentMethod "CREDIT_CARD"}}>Credit Card</option>
            <option value="ONLINE" selected={{eq this.formPaymentMethod "ONLINE"}}>Online</option>
          </select>
        </div>
      </div>
      <div class="flex col gap-2">
        <label class="font-sm text-muted" for="tx-desc">Description</label>
        <input id="tx-desc" type="text"
          class="form-input"
          placeholder="e.g. Monthly rent payment" value={{this.formDescription}} {{on "input" (fn this.setField "formDescription")}} />
      </div>
      <div class="flex gap-4">
        <div class="flex col gap-2 flex-1">
          <label class="font-sm text-muted" for="tx-date">Date</label>
          <input id="tx-date" type="date"
            class="form-input"
            value={{this.formDate}} {{on "change" (fn this.setField "formDate")}} />
        </div>
        <div class="flex col gap-2 flex-1">
          <label class="font-sm text-muted" for="tx-status">Status</label>
          <select id="tx-status" class="form-input" {{on "change" (fn this.setField "formStatus")}}>
            <option value="PENDING" selected={{eq this.formStatus "PENDING"}}>Pending</option>
            <option value="COMPLETED" selected={{eq this.formStatus "COMPLETED"}}>Completed</option>
            <option value="CANCELLED" selected={{eq this.formStatus "CANCELLED"}}>Cancelled</option>
            <option value="FAILED" selected={{eq this.formStatus "FAILED"}}>Failed</option>
          </select>
        </div>
      </div>
      {{#if this.errorMsg}}
        <p class="font-sm text-danger">{{this.errorMsg}}</p>
      {{/if}}
      <div class="flex gap-3 mt-2">
        <button type="button" class="btn btn-secondary" {{on "click" this.closeModal}}>Cancel</button>
        <button type="submit" class="btn btn-primary" disabled={{this.isSaving}}>
          {{if this.isSaving "Saving..." (if this.editTransaction "Update" "Create")}}
        </button>
      </div>
    </form>
  </div>
{{/if}}
