{{page-title "Commissions"}}

<div data-test-commissions-page class="flex col gap-6">
  <div class="flex between x-center">
    <div>
      <h2 class="font-3xl font-bold"><Ph @icon="hand-coins" @size="28px" /> Commissions</h2>
      <p class="text-muted mt-1">Track agent commissions and payouts.</p>
    </div>
    <div class="flex gap-3 x-end">
      <div class="flex col gap-1">
        <FormDropdown @label="Filter by Status" @value={{this.filterStatus}} @onChange={{fn this.setField "filterStatus"}} @options={{this.filterStatusOptions}} @placeholder="All" />
      </div>
      <button type="button" class="btn btn-primary" data-test-add-commission {{on "click" this.openCreate}}>
        <Ph @icon="plus" /> New Commission
      </button>
    </div>
  </div>

  <div class="data-table-wrapper">
    {{#if this.filteredCommissions.length}}
      <table class="data-table" data-test-commissions-table>
        <thead>
          <tr>
            <th>Agent</th>
            <th>Deal ID</th>
            <th>Type</th>
            <th>Amount</th>
            <th>Rate</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {{#each this.filteredCommissions as |comm|}}
            <tr data-test-commission-row>
              <td class="font-xs">{{truncate-id comm.agentId}}</td>
              <td class="font-xs">
                {{#if comm.leadId}}
                  {{truncate-id comm.leadId}}
                {{else if comm.transactionId}}
                  {{truncate-id comm.transactionId}}
                {{else}}
                  <span class="text-muted">N/A</span>
                {{/if}}
              </td>
              <td>
                <span class="type-badge type-{{lowercase comm.type}}">{{comm.type}}</span>
              </td>
              <td class="font-bold">{{format-currency comm.commissionAmount}} / {{format-currency comm.grossAmount}}</td>
              <td>{{comm.commissionRate}}%</td>
              <td>
                <span class="status-badge status-{{lowercase comm.status}}">{{comm.status}}</span>
              </td>
              <td>
                {{#if (eq comm.status "PENDING")}}
                  <button
                    data-test-approve-btn
                    type="button"
                    class="btn btn-primary btn-sm"
                    {{on "click" (fn this.approveCommission comm)}}
                  >
                    <Ph @icon="check" /> Approve
                  </button>
                {{else if (eq comm.status "APPROVED")}}
                  <button
                    data-test-pay-btn
                    type="button"
                    class="btn btn-primary btn-sm"
                    {{on "click" (fn this.payCommission comm)}}
                  >
                    <Ph @icon="currency-dollar" /> Mark Paid
                  </button>
                {{else if (eq comm.status "PAID")}}
                  <span class="font-xs text-muted">
                    {{#if comm.paidAt}}
                      Paid {{comm.paidAt}}
                    {{else}}
                      Paid
                    {{/if}}
                  </span>
                {{/if}}
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <div class="glass-panel p-8 text-center">
        <Ph @icon="hand-coins" @size="32px" @color="var(--text-muted)" />
        <p class="text-muted mt-2">No commissions found.</p>
      </div>
    {{/if}}
  </div>
</div>

<Modal
  @isOpen={{this.showModal}}
  @title="New Commission"
  @onClose={{this.closeModal}}
  @showClose={{true}}
>
  {{#if this.errorMsg}}
    <p class="text-danger" data-test-error>{{this.errorMsg}}</p>
  {{/if}}
  <form class="flex col gap-4" {{on "submit" this.saveCommission}}>
    <FormDropdown @label="Agent" @value={{this.formAgentId}} @onChange={{fn this.setField "formAgentId"}} @options={{this.agentOptions}} @placeholder="Select agent..." @required={{true}} data-test-input-agent />
    <FormDropdown @label="Type" @value={{this.formType}} @onChange={{fn this.setField "formType"}} @options={{this.commissionTypeOptions}} @placeholder="Select type..." @required={{true}} data-test-input-type />
    <FormInput @label="Gross Amount" @type="number" @placeholder="e.g. 50000" @value={{this.formGrossAmount}} @onChange={{fn this.setField "formGrossAmount"}} @required={{true}} data-test-input-amount />
    <FormInput @label="Commission Rate %" @type="number" @placeholder="e.g. 2.5" @value={{this.formCommissionRate}} @onChange={{fn this.setField "formCommissionRate"}} @required={{true}} data-test-input-rate />
    <FormTextarea @label="Notes" @placeholder="Optional notes..." @value={{this.formNotes}} @onChange={{fn this.setField "formNotes"}} data-test-input-notes />
    <div class="flex gap-3 mt-2">
      <AppButton @variant="secondary" @text="Cancel" @onClick={{this.closeModal}} />
      <AppButton @variant="primary" @buttonType="submit" @text="Create" @loading={{this.isSaving}} @loadingText="Saving..." data-test-save-commission />
    </div>
  </form>
</Modal>
