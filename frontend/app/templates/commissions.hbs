{{page-title "Commissions"}}

<div data-test-commissions-page class="flex col gap-6">
  <div class="flex between x-center">
    <div>
      <h2 class="font-3xl font-bold"><Ph @icon="hand-coins" @size="28px" /> Commissions</h2>
      <p class="text-muted mt-1">Track agent commissions and payouts.</p>
    </div>
    <div class="flex gap-3 x-center">
      <div class="flex col gap-1">
        <label class="font-xs text-muted">Filter by Status</label>
        <select class="form-input" style="min-width: 160px;" {{on "change" (fn this.setField "filterStatus")}}>
          <option value="" selected={{eq this.filterStatus ""}}>All</option>
          <option value="PENDING" selected={{eq this.filterStatus "PENDING"}}>Pending</option>
          <option value="APPROVED" selected={{eq this.filterStatus "APPROVED"}}>Approved</option>
          <option value="PAID" selected={{eq this.filterStatus "PAID"}}>Paid</option>
        </select>
      </div>
      <button type="button" class="btn btn-primary" data-test-add-commission {{on "click" this.openCreate}}>
        <Ph @icon="plus" /> New Commission
      </button>
    </div>
  </div>

  <div class="data-table-wrapper">
    {{#if this.filteredCommissions.length}}
      <table class="data-table" data-test-commissions-table>
        <thead>
          <tr>
            <th>Agent</th>
            <th>Deal ID</th>
            <th>Type</th>
            <th>Amount</th>
            <th>Rate</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {{#each this.filteredCommissions as |comm|}}
            <tr data-test-commission-row>
              <td class="font-xs">{{truncate-id comm.agentId}}</td>
              <td class="font-xs">
                {{#if comm.leadId}}
                  {{truncate-id comm.leadId}}
                {{else if comm.transactionId}}
                  {{truncate-id comm.transactionId}}
                {{else}}
                  <span class="text-muted">N/A</span>
                {{/if}}
              </td>
              <td>
                <span class="type-badge type-{{lowercase comm.type}}">{{comm.type}}</span>
              </td>
              <td class="font-bold">{{format-currency comm.commissionAmount}} / {{format-currency comm.grossAmount}}</td>
              <td>{{comm.commissionRate}}%</td>
              <td>
                <span class="status-badge status-{{lowercase comm.status}}">{{comm.status}}</span>
              </td>
              <td>
                {{#if (eq comm.status "PENDING")}}
                  <button
                    data-test-approve-btn
                    type="button"
                    class="btn btn-primary btn-sm"
                    {{on "click" (fn this.approveCommission comm)}}
                  >
                    <Ph @icon="check" /> Approve
                  </button>
                {{else if (eq comm.status "APPROVED")}}
                  <button
                    data-test-pay-btn
                    type="button"
                    class="btn btn-primary btn-sm"
                    {{on "click" (fn this.payCommission comm)}}
                  >
                    <Ph @icon="currency-dollar" /> Mark Paid
                  </button>
                {{else if (eq comm.status "PAID")}}
                  <span class="font-xs text-muted">
                    {{#if comm.paidAt}}
                      Paid {{comm.paidAt}}
                    {{else}}
                      Paid
                    {{/if}}
                  </span>
                {{/if}}
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    {{else}}
      <div class="glass-panel p-8 text-center">
        <Ph @icon="hand-coins" @size="32px" @color="var(--text-muted)" />
        <p class="text-muted mt-2">No commissions found.</p>
      </div>
    {{/if}}
  </div>
</div>

{{#if this.showModal}}
  <div class="modal-backdrop" data-test-modal-backdrop {{on "click" this.closeModal}}></div>
  <div class="modal-panel glass-panel p-8 flex col gap-6" data-test-commission-modal>
    <h3 class="font-xl font-bold">New Commission</h3>
    {{#if this.errorMsg}}
      <p class="text-danger" data-test-error>{{this.errorMsg}}</p>
    {{/if}}
    <form {{on "submit" this.saveCommission}}>
      <div class="form-group">
        <label class="form-label">Agent *</label>
        <select class="form-input" data-test-input-agent {{on "change" (fn this.setField "formAgentId")}} required>
          <option value="">Select agent...</option>
          {{#each @model.agents as |agent|}}
            <option value={{agent.id}} selected={{eq agent.id this.formAgentId}}>{{agent.name}}</option>
          {{/each}}
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Type *</label>
        <select class="form-input" data-test-input-type {{on "change" (fn this.setField "formType")}}>
          <option value="SALE" selected={{eq this.formType "SALE"}}>Sale</option>
          <option value="RENTAL" selected={{eq this.formType "RENTAL"}}>Rental</option>
          <option value="REFERRAL" selected={{eq this.formType "REFERRAL"}}>Referral</option>
        </select>
      </div>
      <div class="form-group">
        <label class="form-label">Gross Amount *</label>
        <input type="number" step="0.01" min="0" class="form-input" data-test-input-gross-amount value={{this.formGrossAmount}} {{on "input" (fn this.setField "formGrossAmount")}} required />
      </div>
      <div class="form-group">
        <label class="form-label">Commission Rate (%) *</label>
        <input type="number" step="0.01" min="0" max="100" class="form-input" data-test-input-rate value={{this.formCommissionRate}} {{on "input" (fn this.setField "formCommissionRate")}} required />
      </div>
      <div class="form-group">
        <label class="form-label">Notes</label>
        <textarea class="form-input" data-test-input-notes {{on "input" (fn this.setField "formNotes")}}>{{this.formNotes}}</textarea>
      </div>
      <div class="modal-actions">
        <button type="button" class="btn btn-secondary" {{on "click" this.closeModal}}>
          Cancel
        </button>
        <button type="submit" class="btn btn-primary" disabled={{this.isSaving}} data-test-save-commission>
          {{if this.isSaving "Saving..." "Create"}}
        </button>
      </div>
    </form>
  </div>
{{/if}}
