# Server Configuration
PORT=3010
NODE_ENV=production

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5480
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_DATABASE=aala_land
# NEVER set DB_SYNC=true in production - use migrations
DB_SYNC=false

# Redis Configuration (BullMQ / Caching)
REDIS_HOST=localhost
REDIS_PORT=6470

# Security
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_MINIMUM_64_CHARS_RANDOM_STRING
JWT_EXPIRES_IN=1d

# CORS - comma-separated list of allowed origins
# Example: https://app.aala.land,https://admin.aala.land
CORS_ORIGIN=https://app.aala.land

# AWS S3 (for property media)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
AWS_S3_BUCKET=aala-land-media

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=CHANGE_ME
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME

# Multi-tenant Context
DEFAULT_COMPANY_ID=00000000-0000-0000-0000-000000000000
