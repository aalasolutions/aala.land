# Server Configuration
PORT=3010
NODE_ENV=production

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5480
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_DATABASE=aala_land
# Run `pnpm run db:migration:run` before starting the backend against a new or empty database.

# Redis Configuration (BullMQ / Caching)
REDIS_HOST=localhost
REDIS_PORT=6470

# Google OAuth (Web client ID from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Security
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_MINIMUM_64_CHARS_RANDOM_STRING
JWT_EXPIRES_IN=1d

# CORS - comma-separated list of allowed origins
# Example: https://app.aala.land,https://admin.aala.land
CORS_ORIGIN=https://app.aala.land

# AWS S3 (for property media)
S3_ENDPOINT=CHANGE_ME
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
# Public bucket — property photos/thumbnails only.
AWS_S3_BUCKET=aala-land-media
# Private bucket — documents only (leases, ID copies, title deeds). Must NOT be public-read.
AWS_S3_DOCUMENTS_BUCKET=aala-land-documents

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=CHANGE_ME
WHATSAPP_PHONE_NUMBER_ID=CHANGE_ME

# AI Auto-reply (OpenAI-compatible endpoint — e.g. OLLAMA, OpenAI, etc.)
OLLAMA_HOST=https://your-llm-host/v1
OLLAMA_API_KEY=your-api-key-here
OLLAMA_MODEL=your-model-name
# AI_ENABLED=true
# AI_TEMPERATURE=0.7
# AI_TOP_P=0.9
# AI_REQUEST_TIMEOUT_MS=300000
# AI_HISTORY_LIMIT=40
# AI_MESSAGE_MAX_AGE_S=120
# AI_DEBOUNCE_MS=5000
# AI_HUMAN_SILENCE_MINUTES=20

# Multi-tenant Context
DEFAULT_COMPANY_ID=00000000-0000-0000-0000-000000000000

# App URL (used in invite emails and other transactional links)
APP_URL=http://localhost:4200

# SendGrid (primary email transport — takes precedence over SMTP)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@aala.land

# SMTP (fallback email transport when SendGrid is not configured)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@aala.land

# Billing (provider-agnostic; only the Stripe adapter exists today)
BILLING_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret. Local dev: printed by `stripe listen`. Production: from the
# Stripe Dashboard webhook endpoint config. Read only inside StripeBillingProvider.
STRIPE_WEBHOOK_SECRET=whsec_...
